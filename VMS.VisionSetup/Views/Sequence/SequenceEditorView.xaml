<UserControl x:Class="VMS.VisionSetup.Views.Sequence.SequenceEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:VMS.VisionSetup.Views.Sequence"
             xmlns:vm="clr-namespace:VMS.VisionSetup.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1200" d:DesignHeight="800"
             Background="#1E1E1E">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
        <local:NullToCollapsedInverseConverter x:Key="NullToCollapsedInverseConverter"/>
        <local:ConnectButtonTextConverter x:Key="ConnectButtonTextConverter"/>
        <local:PlcStatusColorConverter x:Key="PlcStatusColorConverter"/>
        <local:ConditionStatusColorConverter x:Key="ConditionStatusColorConverter"/>
        <local:NullableBoolToVisibilityConverter x:Key="NullableBoolToVisibilityConverter"/>

        <!-- ===== 다크테마 공통 스타일 ===== -->

        <!-- 툴바 버튼 -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 다크 TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#0078D4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 다크 ComboBox 토글 버튼 -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Bd" Grid.ColumnSpan="2" CornerRadius="4"
                        Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1"/>
                <Border Grid.Column="1" CornerRadius="0,4,4,0" Background="Transparent">
                    <Path x:Name="Arrow" Data="M0,0 L4,4 L8,0" Stroke="#AAAAAA" StrokeThickness="1.5"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="BorderBrush" Value="#555555"/>
                    <Setter TargetName="Arrow" Property="Stroke" Value="White"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- 다크 ComboBox -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboBoxToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,28,0" VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1"
                                        CornerRadius="4" Margin="0,2,0,0"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 다크 ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 다크 CheckBox -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box" Width="18" Height="18" CornerRadius="3"
                                    Background="#2D2D30" BorderBrush="#555555" BorderThickness="1.5"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check" Data="M3,7 L7,11 L13,3" Stroke="White" StrokeThickness="2"
                                      Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Width="14" Height="14" Stretch="Uniform" Margin="2"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#0078D4"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 팔레트 ListBox 선택 하이라이트 제거 -->
        <Style x:Key="PaletteListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="6,0,6,6"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 모니터 패널 작은 버튼 -->
        <Style x:Key="MonitorSmallButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 툴바 -->
        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="8,6">
            <DockPanel>
                <!-- 왼쪽: 시퀀스 이름 -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="프로세스 시퀀스:" Foreground="#CCCCCC" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding SequenceName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}" Width="200"/>
                </StackPanel>

                <!-- 오른쪽: 버튼 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="디폴트 생성" Command="{Binding GenerateDefaultSequenceCommand}"
                            Background="#0078D4" Style="{StaticResource ToolbarButton}"/>
                    <Button Content="저장" Command="{Binding SaveSequenceCommand}"
                            Background="#43A047" Style="{StaticResource ToolbarButton}"/>

                    <!-- 구분선: 파일 가져오기/내보내기 -->
                    <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>

                    <Button Content="가져오기" Command="{Binding ImportSequenceFromFileCommand}"
                            Background="#455A64" Style="{StaticResource ToolbarButton}"/>
                    <Button Content="내보내기" Command="{Binding ExportSequenceToFileCommand}"
                            Background="#455A64" Style="{StaticResource ToolbarButton}"/>

                    <!-- 구분선: PLC -->
                    <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>

                    <!-- PLC Monitor 토글 버튼 -->
                    <Button Command="{Binding ToggleMonitorPanelCommand}"
                            Background="#6A1B9A" Style="{StaticResource ToolbarButton}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                     Fill="{Binding IsPlcConnected, Converter={StaticResource PlcStatusColorConverter}}"/>
                            <TextBlock Text="PLC Monitor" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 메인 콘텐츠: 3열 (팔레트 | 캔버스+모니터 | 속성) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- 팔레트 (왼쪽) -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="노드 팔레트" Foreground="#CCCCCC"
                               FontWeight="SemiBold" FontSize="13" Margin="10,10,10,8"/>
                    <ListBox ItemsSource="{Binding PaletteItems}"
                             Style="{StaticResource PaletteListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Color}" CornerRadius="6" Padding="10,8"
                                        Margin="2,3" Cursor="Hand"
                                        MouseLeftButtonDown="Palette_MouseLeftButtonDown">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                               FontWeight="SemiBold" FontSize="12"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 캔버스 + 모니터 패널 (중앙) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 캔버스 -->
                <Grid Grid.Row="0">
                <Border Background="#1A1A1A" ClipToBounds="True"
                        AllowDrop="True" Drop="Canvas_Drop" DragOver="Canvas_DragOver">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  x:Name="CanvasScrollViewer">
                        <Canvas x:Name="SequenceCanvas" Width="800" Height="2000"
                                Background="#1A1A1A"
                                MouseLeftButtonDown="Canvas_MouseLeftButtonDown">
                            <!-- 엣지 (연결선) -->
                            <ItemsControl ItemsSource="{Binding Edges}" x:Name="EdgesControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas>
                                            <!-- Bezier 연결선 -->
                                            <Path x:Name="EdgePath" StrokeThickness="2"
                                                  Stroke="{Binding LineColor}"
                                                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  MouseRightButtonDown="Edge_MouseRightButtonDown">
                                                <Path.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="연결선 삭제"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteEdgeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Path.ContextMenu>
                                            </Path>
                                            <!-- 라벨 -->
                                            <TextBlock Text="{Binding Label}" Foreground="{Binding LineColor}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       x:Name="EdgeLabel"/>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 노드 -->
                            <ItemsControl ItemsSource="{Binding Nodes}" x:Name="NodesControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Grid로 감싸서 노드 + 조건 인디케이터 오버레이 -->
                                        <Grid>
                                            <Border x:Name="NodeBorder" CornerRadius="8" Padding="12,8"
                                                    MinWidth="120" MinHeight="40"
                                                    Background="{Binding NodeColor}"
                                                    BorderBrush="Transparent" BorderThickness="2"
                                                    Cursor="Hand"
                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    MouseLeftButtonDown="Node_MouseLeftButtonDown"
                                                    MouseMove="Node_MouseMove"
                                                    MouseLeftButtonUp="Node_MouseLeftButtonUp"
                                                    MouseRightButtonDown="Node_MouseRightButtonDown">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="연결 시작"
                                                                  Command="{Binding PlacementTarget.Tag.StartConnectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        <MenuItem Header="노드 삭제"
                                                                  Command="{Binding PlacementTarget.Tag.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{Binding NodeIcon}" Stroke="White" StrokeThickness="1.5"
                                                          Fill="Transparent" Width="18" Height="18"
                                                          Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding Name}" Foreground="White"
                                                               FontWeight="SemiBold" FontSize="12"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- 조건 충족 인디케이터 (우상단 오버레이) -->
                                            <Ellipse x:Name="ConditionIndicator"
                                                     Width="12" Height="12"
                                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                                     Margin="0,-4,-4,0"
                                                     Stroke="#1A1A1A" StrokeThickness="1.5"
                                                     Fill="{Binding ConditionIndicatorColor}"
                                                     Visibility="{Binding HasConditionStatus, Converter={StaticResource BoolToVisibility}}"
                                                     IsHitTestVisible="False"/>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <!-- 선택 상태 -->
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#FFFFFF"/>
                                            </DataTrigger>
                                            <!-- 실행 활성 상태 -->
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#FFD700"/>
                                                <Setter TargetName="NodeBorder" Property="BorderThickness" Value="3"/>
                                            </DataTrigger>
                                            <!-- PLC 모니터: 조건 충족 (초록 Glow) -->
                                            <DataTrigger Binding="{Binding ConditionStatus}" Value="True">
                                                <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#4CAF50"/>
                                                <Setter TargetName="NodeBorder" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#4CAF50" ShadowDepth="0"
                                                                          BlurRadius="15" Opacity="0.8"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <!-- PLC 모니터: 조건 미충족 (빨강 Pulse Glow) -->
                                            <DataTrigger Binding="{Binding ConditionStatus}" Value="False">
                                                <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#F44336"/>
                                                <Setter TargetName="NodeBorder" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect x:Name="RedGlow" Color="#F44336"
                                                                          ShadowDepth="0" BlurRadius="15" Opacity="0.8"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="PulseStoryboard">
                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="NodeBorder"
                                                                Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                From="0.3" To="1.0" Duration="0:0:0.6"/>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="NodeBorder"
                                                                Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                From="8" To="20" Duration="0:0:0.6"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>
                    </ScrollViewer>
                </Border>

                <!-- PLC 모니터 범례 (우상단 오버레이) -->
                <Border Background="#CC1E1E1E" CornerRadius="6" Padding="10,8"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,8,8,0" IsHitTestVisible="False"
                        Visibility="{Binding IsPlcMonitoring, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="PLC Monitor" Foreground="#AAAAAA" FontSize="10"
                                   FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <!-- 조건 충족 -->
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Border Width="16" Height="16" CornerRadius="4" Margin="0,0,6,0"
                                    BorderBrush="#4CAF50" BorderThickness="2" Background="Transparent">
                                <Border.Effect>
                                    <DropShadowEffect Color="#4CAF50" ShadowDepth="0" BlurRadius="6" Opacity="0.8"/>
                                </Border.Effect>
                            </Border>
                            <TextBlock Text="조건 충족" Foreground="#4CAF50" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- 조건 미충족 -->
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Border Width="16" Height="16" CornerRadius="4" Margin="0,0,6,0"
                                    BorderBrush="#F44336" BorderThickness="2" Background="Transparent">
                                <Border.Effect>
                                    <DropShadowEffect Color="#F44336" ShadowDepth="0" BlurRadius="6" Opacity="0.8"/>
                                </Border.Effect>
                            </Border>
                            <TextBlock Text="조건 미충족" Foreground="#F44336" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- 선택됨 -->
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Border Width="16" Height="16" CornerRadius="4" Margin="0,0,6,0"
                                    BorderBrush="#FFFFFF" BorderThickness="2" Background="Transparent"/>
                            <TextBlock Text="선택됨" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                </Grid>

                <!-- PLC I/O 모니터 패널 (하단 접이식) -->
                <Border Grid.Row="1" Background="#1E1E2D" BorderBrush="#3F3F46" BorderThickness="0,1,0,0"
                        MaxHeight="250"
                        Visibility="{Binding IsMonitorPanelVisible, Converter={StaticResource BoolToVisibility}}">
                    <DockPanel>
                        <!-- 모니터 패널 헤더 -->
                        <Border DockPanel.Dock="Top" Background="#2D2D40" Padding="8,4">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="PLC I/O Monitor" Foreground="#CCCCCC"
                                               FontWeight="SemiBold" FontSize="12" Margin="0,0,10,0"/>
                                    <Ellipse Width="8" Height="8" Margin="0,0,4,0"
                                             Fill="{Binding IsPlcConnected, Converter={StaticResource PlcStatusColorConverter}}"/>
                                    <TextBlock Text="{Binding PlcConnectionStatus}" Foreground="#999999" FontSize="11"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Command="{Binding ConnectPlcCommand}"
                                            Content="{Binding IsPlcConnected, Converter={StaticResource ConnectButtonTextConverter}}"
                                            Background="#3E3E52" Padding="8,3" Margin="4,0"
                                            Style="{StaticResource MonitorSmallButton}"/>
                                    <Button Content="X" Command="{Binding ToggleMonitorPanelCommand}"
                                            Background="Transparent" Foreground="#999999" Padding="6,3"
                                            Style="{StaticResource MonitorSmallButton}" FontWeight="Bold"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- 모니터 데이터 그리드 -->
                        <DataGrid ItemsSource="{Binding MonitorItems}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="#1E1E2D" Foreground="#CCCCCC"
                                  BorderThickness="0" GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#333344"
                                  RowBackground="#1E1E2D" AlternatingRowBackground="#222233"
                                  HeadersVisibility="Column" CanUserResizeRows="False"
                                  FontFamily="Consolas" FontSize="12"
                                  SelectionMode="Single" SelectionUnit="FullRow"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2D2D40"/>
                                    <Setter Property="Foreground" Value="#AAAAAA"/>
                                    <Setter Property="Padding" Value="6,4"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="#3F3F46"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="6,3"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#333355"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <!-- 상태 인디케이터 -->
                                <DataGridTemplateColumn Header="" Width="30">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="10" Height="10"
                                                     Fill="{Binding ConditionColor}"
                                                     HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- I/O 방향 -->
                                <DataGridTextColumn Header="I/O" Binding="{Binding Direction}" Width="55"/>
                                <!-- 주소 -->
                                <DataGridTextColumn Header="주소" Binding="{Binding Address}" Width="80"/>
                                <!-- 타입 -->
                                <DataGridTextColumn Header="타입" Binding="{Binding DataType}" Width="55"/>
                                <!-- 현재값 -->
                                <DataGridTemplateColumn Header="현재값" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CurrentValue}" FontWeight="Bold"
                                                       Foreground="{Binding ConditionColor}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- 참조 노드 -->
                                <DataGridTextColumn Header="참조 노드" Binding="{Binding ReferencedNodes}" Width="*"/>
                                <!-- 갱신 시각 -->
                                <DataGridTextColumn Header="갱신" Binding="{Binding LastUpdated}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- 속성 패널 (오른쪽) -->
            <Border Grid.Column="2" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="노드 속성" Foreground="#CCCCCC"
                               FontWeight="SemiBold" FontSize="13" Margin="10,10,10,0"/>

                    <!-- 선택된 노드가 없을 때 -->
                    <TextBlock Text="노드를 선택하세요" Foreground="#666666" FontSize="12"
                               Margin="10,20" VerticalAlignment="Top"
                               Visibility="{Binding SelectedNode, Converter={StaticResource NullToCollapsedInverseConverter}}"/>

                    <!-- 선택된 노드 속성 -->
                    <local:SequenceNodePropertiesView DataContext="{Binding}"
                                                      Visibility="{Binding SelectedNode, Converter={StaticResource NullToCollapsedConverter}}"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- 상태 바 -->
        <Border Grid.Row="2" Background="#007ACC" Padding="8,4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="11"/>
                    <TextBlock Text="  |  " Foreground="#80FFFFFF" Margin="8,0"/>
                    <TextBlock Foreground="#CCCCCC" FontSize="11">
                        <Run Text="노드:"/>
                        <Run Text="{Binding Nodes.Count, Mode=OneWay}"/>
                        <Run Text="  연결:"/>
                        <Run Text="{Binding Edges.Count, Mode=OneWay}"/>
                    </TextBlock>
                    <!-- 연결 모드 표시 -->
                    <TextBlock Text="  [연결 모드: 대상 노드를 클릭하세요]" Foreground="#FFD700" FontSize="11"
                               Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibility}}"/>
                    <!-- 저장 위치 표시 -->
                    <TextBlock Foreground="#80FFFFFF" FontSize="11">
                        <Run Text="  |  "/>
                        <Run Text="{Binding CurrentFilePath, Mode=OneWay, TargetNullValue='시스템 시퀀스'}"/>
                    </TextBlock>
                </StackPanel>

                <!-- PLC 연결 상태 (오른쪽) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse Width="8" Height="8" Margin="0,0,4,0"
                             Fill="{Binding IsPlcConnected, Converter={StaticResource PlcStatusColorConverter}}"/>
                    <TextBlock Text="{Binding PlcConnectionStatus}" Foreground="#CCCCCC" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
