<UserControl x:Class="VMS.VisionSetup.Views.ToolSettings.Tools.CodeReaderToolSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VMS.VisionSetup.Controls"
             xmlns:cr="clr-namespace:VMS.VisionSetup.VisionTools.CodeReading"
             xmlns:conv="clr-namespace:VMS.VisionSetup.Converters">
    <StackPanel>
        <!-- Detection -->
        <Expander IsExpanded="True" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Detection" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:EnumComboBoxParameter Label="Code Reader Mode"
                    ItemsSource="{conv:EnumValues {x:Type cr:CodeReaderMode}}"
                    SelectedValue="{Binding CodeReaderMode}"
                    ToolType="CodeReaderTool" ParameterName="CodeReaderMode"/>
                <controls:SliderParameter Label="Max Code Count"
                    Value="{Binding MaxCodeCount}" Minimum="1" Maximum="50"
                    TickFrequency="1" ValueFormat="F0"
                    ToolType="CodeReaderTool" ParameterName="MaxCodeCount"/>
                <controls:CheckBoxParameter Label="Try Harder"
                    IsChecked="{Binding TryHarder}"
                    ToolType="CodeReaderTool" ParameterName="TryHarder"/>
            </StackPanel>
        </Expander>

        <!-- Verification -->
        <Expander IsExpanded="True" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Verification" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:CheckBoxParameter Label="Enable Verification"
                    IsChecked="{Binding EnableVerification}"
                    ToolType="CodeReaderTool" ParameterName="EnableVerification"/>
                <controls:TextBoxParameter Label="Expected Text"
                    Value="{Binding ExpectedText}"
                    ToolType="CodeReaderTool" ParameterName="ExpectedText"/>
                <controls:CheckBoxParameter Label="Use Regex Match"
                    IsChecked="{Binding UseRegexMatch}"
                    ToolType="CodeReaderTool" ParameterName="UseRegexMatch"/>
            </StackPanel>
        </Expander>

        <!-- Display -->
        <Expander IsExpanded="False" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Display" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:CheckBoxParameter Label="Draw Overlay"
                    IsChecked="{Binding DrawOverlay}"
                    ToolType="CodeReaderTool" ParameterName="DrawOverlay"/>
            </StackPanel>
        </Expander>
    </StackPanel>
</UserControl>
