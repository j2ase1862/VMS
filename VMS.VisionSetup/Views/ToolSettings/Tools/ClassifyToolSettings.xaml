<UserControl x:Class="VMS.VisionSetup.Views.ToolSettings.Tools.ClassifyToolSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VMS.VisionSetup.Controls">
    <StackPanel>
        <!-- Model -->
        <Expander IsExpanded="True" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Model" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:TextBoxParameter Label="Model Path (.onnx)"
                    Value="{Binding ModelPath}"
                    ToolType="ClassifyTool" ParameterName="ModelPath"/>
                <controls:SliderParameter Label="Input Width"
                    Value="{Binding InputWidth}" Minimum="32" Maximum="640"
                    TickFrequency="32" ValueFormat="F0"
                    ToolType="ClassifyTool" ParameterName="InputWidth"/>
                <controls:SliderParameter Label="Input Height"
                    Value="{Binding InputHeight}" Minimum="32" Maximum="640"
                    TickFrequency="32" ValueFormat="F0"
                    ToolType="ClassifyTool" ParameterName="InputHeight"/>
            </StackPanel>
        </Expander>

        <!-- Classification -->
        <Expander IsExpanded="True" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Classification" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:SliderParameter Label="Confidence Threshold"
                    Value="{Binding ConfidenceThreshold}" Minimum="0.1" Maximum="1.0"
                    TickFrequency="0.05" ValueFormat="F2"
                    ToolType="ClassifyTool" ParameterName="ConfidenceThreshold"/>
                <controls:TextBoxParameter Label="Class Names (comma-separated)"
                    Value="{Binding ClassNamesText}"
                    ToolType="ClassifyTool" ParameterName="ClassNamesText"/>
                <controls:CheckBoxParameter Label="Use ImageNet Normalization"
                    IsChecked="{Binding UseImageNetNormalization}"
                    ToolType="ClassifyTool" ParameterName="UseImageNetNormalization"/>
            </StackPanel>
        </Expander>

        <!-- Display -->
        <Expander IsExpanded="False" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Display" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:CheckBoxParameter Label="Draw Overlay"
                    IsChecked="{Binding DrawOverlay}"
                    ToolType="ClassifyTool" ParameterName="DrawOverlay"/>
            </StackPanel>
        </Expander>
    </StackPanel>
</UserControl>
