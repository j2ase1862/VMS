<UserControl x:Class="VMS.VisionSetup.Views.ToolSettings.Tools.BlobToolSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VMS.VisionSetup.Controls"
             xmlns:blob="clr-namespace:VMS.VisionSetup.VisionTools.BlobAnalysis"
             xmlns:conv="clr-namespace:VMS.VisionSetup.Converters">
    <StackPanel>
        <!-- Segmentation -->
        <Expander IsExpanded="True" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Segmentation" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:CheckBoxParameter Label="Use Internal Threshold"
                    IsChecked="{Binding UseInternalThreshold}"
                    ToolType="BlobTool" ParameterName="UseInternalThreshold"/>
                <controls:SliderParameter Label="Threshold Value"
                    Value="{Binding ThresholdValue}" Minimum="0" Maximum="255"
                    TickFrequency="1" ValueFormat="F0"
                    ToolType="BlobTool" ParameterName="ThresholdValue"/>
                <controls:EnumComboBoxParameter Label="Segmentation Polarity"
                    ItemsSource="{conv:EnumValues {x:Type blob:SegmentationPolarity}}"
                    SelectedValue="{Binding SegmentationPolarity}"
                    ToolType="BlobTool" ParameterName="SegmentationPolarity"/>
            </StackPanel>
        </Expander>

        <!-- Area Filter -->
        <Expander IsExpanded="True" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Area Filter" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:TextBoxParameter Label="Min Area"
                    Value="{Binding MinArea}"
                    ToolType="BlobTool" ParameterName="MinArea"/>
                <controls:TextBoxParameter Label="Max Area"
                    Value="{Binding MaxArea}"
                    ToolType="BlobTool" ParameterName="MaxArea"/>
            </StackPanel>
        </Expander>

        <!-- Shape Filter -->
        <Expander IsExpanded="False" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Shape Filter" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:SliderParameter Label="Min Circularity"
                    Value="{Binding MinCircularity}" Minimum="0" Maximum="1"
                    TickFrequency="0.05" ValueFormat="F2"
                    ToolType="BlobTool" ParameterName="MinCircularity"/>
                <controls:SliderParameter Label="Max Circularity"
                    Value="{Binding MaxCircularity}" Minimum="0" Maximum="1"
                    TickFrequency="0.05" ValueFormat="F2"
                    ToolType="BlobTool" ParameterName="MaxCircularity"/>
                <controls:TextBoxParameter Label="Min Perimeter"
                    Value="{Binding MinPerimeter}"
                    ToolType="BlobTool" ParameterName="MinPerimeter"/>
                <controls:TextBoxParameter Label="Max Perimeter"
                    Value="{Binding MaxPerimeter}"
                    ToolType="BlobTool" ParameterName="MaxPerimeter"/>
                <controls:TextBoxParameter Label="Min Aspect Ratio"
                    Value="{Binding MinAspectRatio}"
                    ToolType="BlobTool" ParameterName="MinAspectRatio"/>
                <controls:TextBoxParameter Label="Max Aspect Ratio"
                    Value="{Binding MaxAspectRatio}"
                    ToolType="BlobTool" ParameterName="MaxAspectRatio"/>
                <controls:SliderParameter Label="Min Convexity"
                    Value="{Binding MinConvexity}" Minimum="0" Maximum="1"
                    TickFrequency="0.05" ValueFormat="F2"
                    ToolType="BlobTool" ParameterName="MinConvexity"/>
            </StackPanel>
        </Expander>

        <!-- Sort & Limit -->
        <Expander IsExpanded="False" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Sort &amp; Limit" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:EnumComboBoxParameter Label="Sort By"
                    ItemsSource="{conv:EnumValues {x:Type blob:BlobSortBy}}"
                    SelectedValue="{Binding SortBy}"
                    ToolType="BlobTool" ParameterName="SortBy"/>
                <controls:CheckBoxParameter Label="Sort Descending"
                    IsChecked="{Binding SortDescending}"
                    ToolType="BlobTool" ParameterName="SortDescending"/>
                <controls:SliderParameter Label="Max Blob Count"
                    Value="{Binding MaxBlobCount}" Minimum="1" Maximum="100"
                    TickFrequency="1" ValueFormat="F0"
                    ToolType="BlobTool" ParameterName="MaxBlobCount"/>
            </StackPanel>
        </Expander>

        <!-- Judgment -->
        <Expander IsExpanded="True" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Judgment" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:CheckBoxParameter Label="Enable Judgment"
                    IsChecked="{Binding EnableJudgment}"
                    ToolType="BlobTool" ParameterName="EnableJudgment"/>

                <!-- Area Judgment -->
                <controls:CheckBoxParameter Label="Use Area Judgment"
                    IsChecked="{Binding UseAreaJudgment}"
                    ToolType="BlobTool" ParameterName="UseAreaJudgment"/>
                <controls:TextBoxParameter Label="Expected Area"
                    Value="{Binding ExpectedArea}"
                    ToolType="BlobTool" ParameterName="ExpectedArea"/>
                <controls:TextBoxParameter Label="Area Tolerance (+)"
                    Value="{Binding AreaTolerancePlus}"
                    ToolType="BlobTool" ParameterName="AreaTolerancePlus"/>
                <controls:TextBoxParameter Label="Area Tolerance (-)"
                    Value="{Binding AreaToleranceMinus}"
                    ToolType="BlobTool" ParameterName="AreaToleranceMinus"/>

                <!-- Count Judgment -->
                <controls:CheckBoxParameter Label="Use Count Judgment"
                    IsChecked="{Binding UseCountJudgment}"
                    ToolType="BlobTool" ParameterName="UseCountJudgment"/>
                <controls:EnumComboBoxParameter Label="Count Mode"
                    ItemsSource="{conv:EnumValues {x:Type blob:CountJudgmentMode}}"
                    SelectedValue="{Binding CountMode}"
                    ToolType="BlobTool" ParameterName="CountMode"/>
                <controls:TextBoxParameter Label="Expected Count"
                    Value="{Binding ExpectedCount}"
                    ToolType="BlobTool" ParameterName="ExpectedCount"/>
                <controls:TextBoxParameter Label="Expected Count Max"
                    Value="{Binding ExpectedCountMax}"
                    ToolType="BlobTool" ParameterName="ExpectedCountMax"/>
            </StackPanel>
        </Expander>

        <!-- Display -->
        <Expander IsExpanded="False" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Display" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:CheckBoxParameter Label="Draw Contours"
                    IsChecked="{Binding DrawContours}"
                    ToolType="BlobTool" ParameterName="DrawContours"/>
                <controls:CheckBoxParameter Label="Draw Bounding Box"
                    IsChecked="{Binding DrawBoundingBox}"
                    ToolType="BlobTool" ParameterName="DrawBoundingBox"/>
                <controls:CheckBoxParameter Label="Draw Center Point"
                    IsChecked="{Binding DrawCenterPoint}"
                    ToolType="BlobTool" ParameterName="DrawCenterPoint"/>
                <controls:CheckBoxParameter Label="Draw Labels"
                    IsChecked="{Binding DrawLabels}"
                    ToolType="BlobTool" ParameterName="DrawLabels"/>
            </StackPanel>
        </Expander>
    </StackPanel>
</UserControl>
