<UserControl x:Class="VMS.VisionSetup.Views.ToolSettings.Tools.AnomalyToolSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VMS.VisionSetup.Controls">
    <StackPanel>
        <!-- Model -->
        <Expander IsExpanded="True" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Model" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:TextBoxParameter Label="Model Path (.onnx)"
                    Value="{Binding ModelPath}"
                    ToolType="AnomalyTool" ParameterName="ModelPath"/>
                <controls:SliderParameter Label="Input Size"
                    Value="{Binding InputSize}" Minimum="64" Maximum="512"
                    TickFrequency="32" ValueFormat="F0"
                    ToolType="AnomalyTool" ParameterName="InputSize"/>
            </StackPanel>
        </Expander>

        <!-- Anomaly Detection -->
        <Expander IsExpanded="True" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Anomaly Detection" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:SliderParameter Label="Anomaly Threshold"
                    Value="{Binding AnomalyThreshold}" Minimum="0.0" Maximum="1.0"
                    TickFrequency="0.05" ValueFormat="F2"
                    ToolType="AnomalyTool" ParameterName="AnomalyThreshold"/>
            </StackPanel>
        </Expander>

        <!-- Display -->
        <Expander IsExpanded="True" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Display" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:CheckBoxParameter Label="Draw Overlay"
                    IsChecked="{Binding DrawOverlay}"
                    ToolType="AnomalyTool" ParameterName="DrawOverlay"/>
                <controls:CheckBoxParameter Label="Show Heatmap"
                    IsChecked="{Binding ShowHeatmap}"
                    ToolType="AnomalyTool" ParameterName="ShowHeatmap"/>
                <controls:SliderParameter Label="Heatmap Opacity"
                    Value="{Binding HeatmapOpacity}" Minimum="0.0" Maximum="1.0"
                    TickFrequency="0.05" ValueFormat="F2"
                    ToolType="AnomalyTool" ParameterName="HeatmapOpacity"/>
            </StackPanel>
        </Expander>
    </StackPanel>
</UserControl>
