<UserControl x:Class="VMS.VisionSetup.Views.ToolSettings.Tools.GeometryToolSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VMS.VisionSetup.Controls"
             xmlns:conv="clr-namespace:VMS.VisionSetup.Converters"
             xmlns:meas="clr-namespace:VMS.VisionSetup.VisionTools.Measurement">
    <StackPanel>
        <controls:EnumComboBoxParameter Label="Operation"
            ItemsSource="{conv:EnumValues {x:Type meas:GeometryOperation}}"
            SelectedValue="{Binding Operation}"
            ToolType="GeometryTool" ParameterName="Operation"/>

        <!-- Connected Source Geometries -->
        <TextBlock Text="Source Geometries" Foreground="#AAAAAA" FontWeight="Bold"
                   Margin="0,10,0,5" FontSize="12"/>

        <ItemsControl ItemsSource="{Binding SourceGeometries}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                            Padding="4,3" Margin="0,1">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Foreground="#CCCCCC" FontSize="11">
                                <Run Text="{Binding ToolName, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Foreground="#999999" FontSize="10" Margin="0,2,0,0">
                                <Run Text="{Binding Type, Mode=OneWay}"/>
                                <Run Text=" — "/>
                                <Run Text="("/>
                                <Run Text="{Binding X, StringFormat=F1, Mode=OneWay}"/>
                                <Run Text=", "/>
                                <Run Text="{Binding Y, StringFormat=F1, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="No source geometries connected" Foreground="#666666"
                   FontSize="11" Margin="0,5,0,0" FontStyle="Italic">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SourceGeometries.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </StackPanel>
</UserControl>
