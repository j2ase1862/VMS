<UserControl x:Class="VMS.VisionSetup.Views.ToolSettings.Tools.CaliperToolSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VMS.VisionSetup.Controls"
             xmlns:conv="clr-namespace:VMS.VisionSetup.Converters"
             xmlns:meas="clr-namespace:VMS.VisionSetup.VisionTools.Measurement">
    <StackPanel>
        <!-- Edge Detection -->
        <Expander IsExpanded="True" Style="{StaticResource SettingExpanderStyle}">
            <Expander.Header>
                <TextBlock Text="Edge Detection" Style="{StaticResource ExpanderHeaderStyle}"/>
            </Expander.Header>
            <StackPanel Margin="5,0,0,0">
                <controls:EnumComboBoxParameter Label="Polarity"
                    ItemsSource="{conv:EnumValues {x:Type meas:EdgePolarity}}"
                    SelectedValue="{Binding Polarity}"
                    ToolType="CaliperTool" ParameterName="Polarity"/>
                <controls:SliderParameter Label="Edge Threshold"
                    Value="{Binding EdgeThreshold}" Minimum="1" Maximum="100"
                    TickFrequency="1" ValueFormat="F0"
                    ToolType="CaliperTool" ParameterName="EdgeThreshold"/>
                <controls:SliderParameter Label="Filter Half Width"
                    Value="{Binding FilterHalfWidth}" Minimum="1" Maximum="10"
                    TickFrequency="1" SnapToTick="True" ValueFormat="F0"
                    ToolType="CaliperTool" ParameterName="FilterHalfWidth"/>
                <controls:EnumComboBoxParameter Label="Mode"
                    ItemsSource="{conv:EnumValues {x:Type meas:CaliperMode}}"
                    SelectedValue="{Binding Mode}"
                    ToolType="CaliperTool" ParameterName="Mode"/>
                <controls:SliderParameter Label="Max Edges"
                    Value="{Binding MaxEdges}" Minimum="1" Maximum="50"
                    TickFrequency="1" SnapToTick="True" ValueFormat="F0"
                    ToolType="CaliperTool" ParameterName="MaxEdges"/>
                <controls:EnumComboBoxParameter Label="Selection Mode"
                    ItemsSource="{conv:EnumValues {x:Type meas:ScorerMode}}"
                    SelectedValue="{Binding ScorerMode}"
                    ToolType="CaliperTool" ParameterName="ScorerMode"/>
            </StackPanel>
        </Expander>

    </StackPanel>
</UserControl>
