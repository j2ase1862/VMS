<UserControl x:Class="VMS.VisionSetup.Views.ToolSettings.Tools.ResultToolSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VMS.VisionSetup.Controls"
             xmlns:conv="clr-namespace:VMS.VisionSetup.Converters"
             xmlns:result="clr-namespace:VMS.VisionSetup.VisionTools.Result">
    <StackPanel>
        <controls:EnumComboBoxParameter Label="Judgment Mode"
            ItemsSource="{conv:EnumValues {x:Type result:ResultJudgmentMode}}"
            SelectedValue="{Binding JudgmentMode}"
            ToolType="ResultTool" ParameterName="JudgmentMode"/>

        <!-- Last Execution Source Results -->
        <TextBlock Text="Source Results" Foreground="#AAAAAA" FontWeight="Bold"
                   Margin="0,10,0,5" FontSize="12"/>

        <ItemsControl ItemsSource="{Binding SourceResults}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                            Padding="4,3" Margin="0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="14" FontWeight="Bold" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,6,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="NG"/>
                                        <Setter Property="Foreground" Value="#FF6B68"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Success}" Value="True">
                                                <Setter Property="Text" Value="OK"/>
                                                <Setter Property="Foreground" Value="#4EC94E"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ToolName}" Foreground="#CCCCCC"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="No source tools connected" Foreground="#666666"
                   FontSize="11" Margin="0,5,0,0" FontStyle="Italic">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SourceResults.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </StackPanel>
</UserControl>
