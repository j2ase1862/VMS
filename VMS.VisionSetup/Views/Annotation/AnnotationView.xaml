<UserControl x:Class="VMS.VisionSetup.Views.Annotation.AnnotationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VMS.VisionSetup.Controls"
             xmlns:annotation="clr-namespace:VMS.VisionSetup.Models.Annotation"
             Background="#1E1E1E">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Left Panel: Dataset & Image List ═══ -->
        <Border Grid.Column="0" Background="#252526" BorderBrush="#333" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Dataset Section -->
                <Expander Grid.Row="0" IsExpanded="True" Margin="5">
                    <Expander.Header>
                        <TextBlock Text="Dataset" Foreground="#FFD700" FontWeight="Bold" FontSize="12"/>
                    </Expander.Header>
                    <StackPanel Margin="0,5,0,0">
                        <!-- Dataset List -->
                        <ListBox ItemsSource="{Binding Datasets}" SelectedItem="{Binding CurrentDataset}"
                                 MaxHeight="100" Background="#1E1E1E" Foreground="#CCC"
                                 BorderBrush="#444" BorderThickness="1" Margin="0,0,0,5">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding TotalImages, StringFormat='({0})'}"
                                                   Foreground="#888" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- New Dataset -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding NewDatasetName, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#EEE" BorderBrush="#555"
                                     Padding="4,2" FontSize="11"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="+" Width="28" Margin="3,0,0,0"
                                    Command="{Binding CreateDatasetCommand}"
                                    Background="#0078D4" Foreground="White" BorderThickness="0"
                                    FontWeight="Bold" Cursor="Hand"/>
                        </Grid>

                        <!-- Dataset Actions -->
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <Button Content="Load" Command="{Binding SelectDatasetCommand}"
                                    CommandParameter="{Binding CurrentDataset}"
                                    Background="#333" Foreground="#CCC" BorderBrush="#555"
                                    Padding="8,2" FontSize="11" Cursor="Hand" Margin="0,0,3,0"/>
                            <Button Content="Save" Command="{Binding SaveDatasetCommand}"
                                    Background="#333" Foreground="#CCC" BorderBrush="#555"
                                    Padding="8,2" FontSize="11" Cursor="Hand" Margin="0,0,3,0"/>
                            <Button Content="Delete" Command="{Binding DeleteDatasetCommand}"
                                    Background="#442222" Foreground="#F88" BorderBrush="#555"
                                    Padding="8,2" FontSize="11" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <!-- Image Actions -->
                <StackPanel Grid.Row="1" Margin="5,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Images" Foreground="#FFD700" FontWeight="Bold"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="+ Add" Command="{Binding AddImagesCommand}"
                                Background="#0078D4" Foreground="White" BorderThickness="0"
                                Padding="8,2" FontSize="11" Cursor="Hand" Margin="0,0,3,0"/>
                        <Button Grid.Column="2" Content="- Del" Command="{Binding RemoveCurrentImageCommand}"
                                Background="#442222" Foreground="#F88" BorderThickness="0"
                                Padding="8,2" FontSize="11" Cursor="Hand"/>
                    </Grid>

                    <!-- Navigation -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Button Content="◀" Command="{Binding PreviousImageCommand}"
                                Width="30" Background="#333" Foreground="#CCC" BorderBrush="#555"
                                FontSize="11" Cursor="Hand" Margin="0,0,3,0"/>
                        <TextBlock VerticalAlignment="Center" Foreground="#AAA" FontSize="11">
                            <Run Text="{Binding CurrentImageIndex, Mode=OneWay, StringFormat='{}{0}'}"
                                 FontWeight="Bold" Foreground="#EEE"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding CurrentDataset.TotalImages, Mode=OneWay, FallbackValue=0}"/>
                        </TextBlock>
                        <Button Content="▶" Command="{Binding NextImageCommand}"
                                Width="30" Background="#333" Foreground="#CCC" BorderBrush="#555"
                                FontSize="11" Cursor="Hand" Margin="3,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Image List -->
                <ListBox Grid.Row="2" ItemsSource="{Binding CurrentDataset.Images}"
                         SelectedItem="{Binding CurrentImage}"
                         Background="#1E1E1E" Foreground="#CCC"
                         BorderThickness="0" Margin="5,0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1" Cursor="Hand">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Labeling status indicator -->
                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                         Fill="{Binding IsLabeled, Converter={StaticResource BoolToVis},
                                                FallbackValue=Gray}"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#666"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLabeled}" Value="True">
                                                    <Setter Property="Fill" Value="#4CAF50"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Grid.Column="1" Text="{Binding ImagePath}"
                                           Foreground="#CCC" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Margin="4,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Labels.Count, StringFormat='[{0}]'}"
                                           Foreground="#888" FontSize="10"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <!-- SelectionChanged triggers navigation -->
                    <ListBox.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick"
                                      Command="{Binding SelectImageCommand}"
                                      CommandParameter="{Binding CurrentImage}"/>
                    </ListBox.InputBindings>
                </ListBox>
            </Grid>
        </Border>

        <!-- ═══ Center: ImageCanvas ═══ -->
        <Grid Grid.Column="1">
            <controls:ImageCanvas x:Name="LabelingCanvas"
                                  SourceImage="{Binding CurrentMat, Mode=OneWay}"
                                  ROICollection="{Binding LabelROIs, Mode=TwoWay}"
                                  SelectedROI="{Binding SelectedROI, Mode=TwoWay}"
                                  IsToolbarVisible="True"
                                  IsROIEditingEnabled="True"
                                  ROICreated="LabelingCanvas_ROICreated"
                                  ROIModified="LabelingCanvas_ROIModified"
                                  ROIDeleted="LabelingCanvas_ROIDeleted"
                                  ROISelectionChanged="LabelingCanvas_ROISelectionChanged"
                                  Margin="5"/>
        </Grid>

        <!-- ═══ Right Panel: Labels & Classes ═══ -->
        <Border Grid.Column="2" Background="#252526" BorderBrush="#333" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Classes Section -->
                <Expander Grid.Row="0" IsExpanded="True" Margin="5">
                    <Expander.Header>
                        <TextBlock Text="Classes" Foreground="#FFD700" FontWeight="Bold" FontSize="12"/>
                    </Expander.Header>
                    <StackPanel Margin="0,5,0,0">
                        <ListBox ItemsSource="{Binding CurrentDataset.Classes}"
                                 SelectedItem="{Binding SelectedClassName}"
                                 MaxHeight="120" Background="#1E1E1E" Foreground="#CCC"
                                 BorderBrush="#444" BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="12" Padding="4,1"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding NewClassName, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#EEE" BorderBrush="#555"
                                     Padding="4,2" FontSize="11"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="+" Width="28" Margin="3,0,0,0"
                                    Command="{Binding AddClassCommand}"
                                    Background="#0078D4" Foreground="White" BorderThickness="0"
                                    FontWeight="Bold" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Labels List -->
                <Grid Grid.Row="1" Margin="5,5,5,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <TextBlock Text="Labels" Foreground="#FFD700" FontWeight="Bold"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <Button Content="Delete" HorizontalAlignment="Right"
                                Command="{Binding DeleteSelectedLabelCommand}"
                                Background="#442222" Foreground="#F88" BorderThickness="0"
                                Padding="6,1" FontSize="10" Cursor="Hand"/>
                    </Grid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding CurrentImage.Labels}"
                             SelectedItem="{Binding SelectedLabel}"
                             Background="#1E1E1E" Foreground="#CCC"
                             BorderBrush="#444" BorderThickness="1" Margin="0,3,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding ClassName}"
                                                   FontWeight="Bold" FontSize="11"
                                                   Foreground="#4FC3F7"/>
                                        <TextBlock Text="{Binding BoundingBox, StringFormat=' [{0}]'}"
                                                   Foreground="#888" FontSize="10" Margin="4,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Transcription}"
                                               Foreground="#AED581" FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Transcription,
                                                   Converter={StaticResource BoolToVis},
                                                   FallbackValue=Collapsed}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Selected Label Editor -->
                <Border Grid.Row="2" Background="#2D2D30" BorderBrush="#444"
                        BorderThickness="0,1,0,0" Margin="5" Padding="5"
                        Visibility="{Binding SelectedLabel,
                            Converter={StaticResource BoolToVis},
                            FallbackValue=Collapsed}">
                    <StackPanel>
                        <TextBlock Text="Selected Label" Foreground="#FFD700"
                                   FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>

                        <!-- Class selection -->
                        <TextBlock Text="Class:" Foreground="#999" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding CurrentDataset.Classes}"
                                  SelectedItem="{Binding SelectedLabel.ClassName}"
                                  Background="#333" Foreground="#EEE" BorderBrush="#555"
                                  FontSize="11" Margin="0,2,0,5"/>

                        <!-- Transcription (OCR label) -->
                        <TextBlock Text="Transcription:" Foreground="#999" FontSize="11"/>
                        <TextBox Text="{Binding SelectedLabel.Transcription, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#333" Foreground="#EEE" BorderBrush="#555"
                                 Padding="4,3" FontSize="12" FontFamily="Consolas"
                                 Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Export & Training Section -->
                <Expander Grid.Row="3" IsExpanded="False" Margin="5,0,5,5">
                    <Expander.Header>
                        <TextBlock Text="Export &amp; Training" Foreground="#FFD700" FontWeight="Bold" FontSize="12"/>
                    </Expander.Header>
                    <StackPanel Margin="0,5,0,0">
                        <!-- Export -->
                        <Button Content="Auto Split (Train/Val)" Command="{Binding AutoSplitCommand}"
                                Background="#333" Foreground="#CCC" BorderBrush="#555"
                                Padding="6,3" FontSize="11" Cursor="Hand" Margin="0,0,0,3"
                                HorizontalAlignment="Stretch"/>
                        <Button Content="Export YOLO" Command="{Binding ExportYoloCommand}"
                                Background="#333" Foreground="#CCC" BorderBrush="#555"
                                Padding="6,3" FontSize="11" Cursor="Hand" Margin="0,0,0,3"
                                HorizontalAlignment="Stretch"/>
                        <Button Content="Export PaddleOCR" Command="{Binding ExportPaddleOcrCommand}"
                                Background="#333" Foreground="#CCC" BorderBrush="#555"
                                Padding="6,3" FontSize="11" Cursor="Hand" Margin="0,0,0,3"
                                HorizontalAlignment="Stretch"/>

                        <!-- Training Config -->
                        <Border BorderBrush="#444" BorderThickness="0,1,0,0" Margin="0,5,0,0" Padding="0,5,0,0">
                            <StackPanel>
                                <TextBlock Text="Training" Foreground="#FF9800" FontWeight="Bold"
                                           FontSize="11" Margin="0,0,0,4"/>

                                <TextBlock Text="Python:" Foreground="#999" FontSize="10"/>
                                <TextBox Text="{Binding TrainingConfig.PythonPath, UpdateSourceTrigger=LostFocus}"
                                         Background="#333" Foreground="#EEE" BorderBrush="#555"
                                         Padding="3,2" FontSize="11" Margin="0,1,0,4"/>

                                <Grid>
                                    <TextBlock Text="Script:" Foreground="#999" FontSize="10"/>
                                    <Button Content="..." HorizontalAlignment="Right" Width="24"
                                            Command="{Binding SelectTrainingScriptCommand}"
                                            Background="#333" Foreground="#CCC" BorderBrush="#555"
                                            FontSize="10" Cursor="Hand" Padding="0"/>
                                </Grid>
                                <TextBox Text="{Binding TrainingConfig.TrainingScriptPath, UpdateSourceTrigger=LostFocus}"
                                         Background="#333" Foreground="#EEE" BorderBrush="#555"
                                         Padding="3,2" FontSize="10" Margin="0,1,0,4"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,2,0">
                                        <TextBlock Text="Epochs:" Foreground="#999" FontSize="10"/>
                                        <TextBox Text="{Binding TrainingConfig.Epochs}"
                                                 Background="#333" Foreground="#EEE" BorderBrush="#555"
                                                 Padding="3,2" FontSize="11"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="2,0,0,0">
                                        <TextBlock Text="Batch:" Foreground="#999" FontSize="10"/>
                                        <TextBox Text="{Binding TrainingConfig.BatchSize}"
                                                 Background="#333" Foreground="#EEE" BorderBrush="#555"
                                                 Padding="3,2" FontSize="11"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Start/Stop -->
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Start Training" Command="{Binding StartTrainingCommand}"
                                            Background="#2E7D32" Foreground="White" BorderThickness="0"
                                            Padding="6,4" FontSize="11" FontWeight="Bold"
                                            Cursor="Hand" Margin="0,0,2,0"/>
                                    <Button Grid.Column="1" Content="Stop"
                                            Command="{Binding StopTrainingCommand}"
                                            Background="#C62828" Foreground="White" BorderThickness="0"
                                            Padding="6,4" FontSize="11" FontWeight="Bold"
                                            Cursor="Hand" Margin="2,0,0,0"/>
                                </Grid>

                                <!-- Progress -->
                                <ProgressBar Value="{Binding TrainingStatus.Progress, Mode=OneWay}"
                                             Minimum="0" Maximum="100" Height="10"
                                             Background="#333" Foreground="#4CAF50"
                                             BorderThickness="0" Margin="0,5,0,2"/>
                                <TextBlock Text="{Binding TrainingStatus.Message, Mode=OneWay}"
                                           Foreground="#AAA" FontSize="10" TextTrimming="CharacterEllipsis"/>

                                <!-- Metrics -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Foreground="#888" FontSize="10">
                                        <Run Text="Loss: "/><Run Text="{Binding TrainingStatus.Loss, Mode=OneWay, StringFormat='F4'}" Foreground="#FF9800"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#888" FontSize="10" Margin="10,0,0,0">
                                        <Run Text="Acc: "/><Run Text="{Binding TrainingStatus.Accuracy, Mode=OneWay, StringFormat='P1'}" Foreground="#4CAF50"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Log -->
                                <ListBox ItemsSource="{Binding TrainingLog}" MaxHeight="100"
                                         Background="#1A1A1A" Foreground="#888" BorderBrush="#333"
                                         BorderThickness="1" FontSize="9" FontFamily="Consolas"
                                         Margin="0,4,0,0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Expander>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <TextBlock Grid.ColumnSpan="3" Text="{Binding StatusMessage}"
                   Foreground="#999" FontSize="11" Margin="8,0"
                   VerticalAlignment="Bottom" Padding="0,0,0,3"/>
    </Grid>
</UserControl>
