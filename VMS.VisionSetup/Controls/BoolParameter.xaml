<UserControl x:Class="VMS.VisionSetup.Controls.BoolParameter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VMS.VisionSetup.Controls"
             x:Name="Root">
    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
        <CheckBox IsChecked="{Binding Value, ElementName=Root, Mode=TwoWay}"
                  VerticalAlignment="Center"/>
        <TextBlock Text="{Binding Label, ElementName=Root}"
                   Foreground="LightGray" FontSize="12"
                   VerticalAlignment="Center" Margin="6,0,0,0"/>
        <controls:HelpIcon ToolType="{Binding ToolType, ElementName=Root}"
                           ParameterName="{Binding ParameterName, ElementName=Root}"
                           Margin="5,0,0,0" VerticalAlignment="Center"/>
    </StackPanel>
</UserControl>
