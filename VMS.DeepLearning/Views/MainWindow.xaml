<Window x:Class="VMS.DeepLearning.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VMS.DeepLearning.ViewModels"
        xmlns:ann="clr-namespace:VMS.Core.Models.Annotation;assembly=VMS.Core"
        Title="{Binding WindowTitle}" Width="1400" Height="900"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#1E1E1E">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- ═══ Toolbar ═══ -->
        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="VMS Labeling" FontSize="16" FontWeight="Bold"
                           Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <Button Content="New Dataset" Command="{Binding CreateDatasetCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,4,0" Padding="10,4"/>
                <Button Content="Save" Command="{Binding SaveDatasetCommand}"
                        Margin="0,0,4,0" Padding="10,4"/>
                <Separator Margin="8,0" Width="1" Background="#555"/>
                <Button Content="Add Images" Command="{Binding AddImagesCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,4,0" Padding="10,4"/>
                <Separator Margin="8,0" Width="1" Background="#555"/>
                <Button Content="Auto Split" Command="{Binding AutoSplitCommand}"
                        Margin="0,0,4,0" Padding="10,4"/>
                <Button Content="Export" Command="{Binding ExportForCurrentTaskCommand}"
                        Style="{StaticResource SuccessButton}" Margin="0,0,4,0" Padding="10,4"/>
            </StackPanel>
        </Border>

        <!-- ═══ Main Content ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ Left Panel: Dataset & Image List ═══ -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Dataset Section -->
                    <Expander Grid.Row="0" IsExpanded="True" Margin="8,8,8,4">
                        <Expander.Header>
                            <TextBlock Text="Dataset" Style="{StaticResource SectionHeader}"/>
                        </Expander.Header>
                        <StackPanel Margin="0,6,0,0">
                            <ListBox ItemsSource="{Binding Datasets}" SelectedItem="{Binding CurrentDataset}"
                                     MaxHeight="120" Margin="0,0,0,6">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <TextBlock Text="{Binding Name}" FontSize="12"/>
                                            <TextBlock Foreground="#888" FontSize="10" Margin="6,0,0,0"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding DatasetTaskType, StringFormat='[{0}]'}"/>
                                                <Run Text="{Binding TotalImages, StringFormat=' ({0})'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- New Dataset: Name + Task Type -->
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding NewDatasetName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="+" Width="30" Margin="4,0,0,0"
                                        Command="{Binding CreateDatasetCommand}"
                                        Style="{StaticResource PrimaryButton}" FontWeight="Bold"/>
                            </Grid>

                            <!-- Task Type Selector -->
                            <ComboBox ItemsSource="{Binding DatasetTaskTypes}"
                                      SelectedItem="{Binding NewDatasetTaskType}"
                                      FontSize="11" Margin="0,4,0,0"/>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Content="Load" Command="{Binding SelectDatasetCommand}"
                                        CommandParameter="{Binding CurrentDataset}"
                                        Padding="10,3" FontSize="11" Margin="0,0,4,0"/>
                                <Button Content="Save" Command="{Binding SaveDatasetCommand}"
                                        Padding="10,3" FontSize="11" Margin="0,0,4,0"/>
                                <Button Content="Delete" Command="{Binding DeleteDatasetCommand}"
                                        Style="{StaticResource DangerButton}" Padding="10,3" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- Image Actions Bar -->
                    <Border Grid.Row="1" Margin="8,4" Padding="0,4"
                            BorderBrush="#3F3F46" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Images" Style="{StaticResource SectionHeader}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="+ Add" Command="{Binding AddImagesCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="8,2" FontSize="11" Margin="0,0,4,0"/>
                                    <Button Content="- Del" Command="{Binding RemoveCurrentImageCommand}"
                                            Style="{StaticResource DangerButton}"
                                            Padding="8,2" FontSize="11"/>
                                </StackPanel>
                            </Grid>

                            <!-- Navigation -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                <Button Content="◀" Command="{Binding PreviousImageCommand}"
                                        Width="34" Padding="0,2" FontSize="12" Margin="0,0,4,0"/>
                                <TextBlock VerticalAlignment="Center" FontSize="12">
                                    <Run Text="{Binding CurrentImageIndex, Mode=OneWay, StringFormat='{}{0}'}"
                                         FontWeight="Bold"/>
                                    <Run Text=" / " Foreground="#888"/>
                                    <Run Text="{Binding CurrentDataset.TotalImages, Mode=OneWay, FallbackValue=0}"
                                         Foreground="#888"/>
                                </TextBlock>
                                <Button Content="▶" Command="{Binding NextImageCommand}"
                                        Width="34" Padding="0,2" FontSize="12" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Image List -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding CurrentDataset.Images}"
                             SelectedItem="{Binding CurrentImage}"
                             BorderThickness="0" Margin="8,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick"
                                          Command="{Binding SelectImageCommand}"
                                          CommandParameter="{Binding CurrentImage}"/>
                        </ListBox.InputBindings>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2" Cursor="Hand">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10"
                                             VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#555"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLabeled}" Value="True">
                                                        <Setter Property="Fill" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Grid.Column="1" Text="{Binding ImagePath}"
                                               FontSize="12" TextTrimming="CharacterEllipsis"
                                               Margin="6,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Labels.Count, StringFormat='[{0}]'}"
                                               Foreground="#888" FontSize="10"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ═══ Center: Image Canvas ═══ -->
            <Grid Grid.Column="1" Background="#1A1A1A">
                <Border Margin="8" Background="#111" BorderBrush="#333" BorderThickness="1">
                    <Grid>
                        <!-- Image display -->
                        <Image x:Name="MainImage" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>

                        <!-- Canvas for bounding box drawing (Detection/OCR) -->
                        <Canvas x:Name="AnnotationCanvas"
                                Background="Transparent"
                                MouseLeftButtonDown="AnnotationCanvas_MouseLeftButtonDown"
                                MouseMove="AnnotationCanvas_MouseMove"
                                MouseLeftButtonUp="AnnotationCanvas_MouseLeftButtonUp"/>

                        <!-- Classification/Anomaly: Current class indicator overlay -->
                        <Border x:Name="ClassIndicatorOverlay"
                                VerticalAlignment="Top" HorizontalAlignment="Right"
                                Margin="16" Padding="12,6" CornerRadius="4"
                                Visibility="Collapsed">
                            <TextBlock x:Name="ClassIndicatorText" FontSize="16" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>

                        <!-- Placeholder text -->
                        <TextBlock Text="이미지를 선택하세요" FontSize="18" Foreground="#555"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding CurrentMat, Converter={StaticResource BoolToVis},
                                       ConverterParameter=Invert, FallbackValue=Visible}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ Right Panel: Classes, Labels, Training ═══ -->
            <Border Grid.Column="2" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">

                        <!-- Classes Section -->
                        <Expander IsExpanded="True" Margin="0,0,0,8">
                            <Expander.Header>
                                <TextBlock Text="Classes" Style="{StaticResource SectionHeader}"/>
                            </Expander.Header>
                            <StackPanel Margin="0,6,0,0">
                                <!-- Classification/Anomaly: 클래스 버튼으로 표시 -->
                                <ItemsControl ItemsSource="{Binding CurrentDataset.Classes}"
                                              Visibility="{Binding IsClassificationMode, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}" Margin="2,2"
                                                    Padding="12,8" FontSize="13" FontWeight="Bold"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.AssignClassCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Background" Value="#3E3E42"/>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Anomaly: good/defect 버튼 -->
                                <StackPanel Visibility="{Binding IsAnomalyMode, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                                    <Button Content="GOOD (정상)" Margin="2,2" Padding="12,10"
                                            FontSize="14" FontWeight="Bold" Cursor="Hand"
                                            Background="#2E7D32" Foreground="White"
                                            Command="{Binding AssignClassCommand}"
                                            CommandParameter="good"/>
                                    <Button Content="DEFECT (불량)" Margin="2,2" Padding="12,10"
                                            FontSize="14" FontWeight="Bold" Cursor="Hand"
                                            Background="#C62828" Foreground="White"
                                            Command="{Binding AssignClassCommand}"
                                            CommandParameter="defect"/>
                                </StackPanel>

                                <!-- Detection/OCR: 기존 클래스 리스트 -->
                                <StackPanel Visibility="{Binding IsBoundingBoxMode, Converter={StaticResource BoolToVis}, FallbackValue=Visible}">
                                    <ListBox ItemsSource="{Binding CurrentDataset.Classes}"
                                             SelectedItem="{Binding SelectedClassName}"
                                             MaxHeight="140">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="13" Padding="4,2"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>

                                <!-- Add class (모든 모드 공통) -->
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding NewClassName, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="12" VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="1" Content="+" Width="30" Margin="4,0,0,0"
                                            Command="{Binding AddClassCommand}"
                                            Style="{StaticResource PrimaryButton}" FontWeight="Bold"/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- Labels Section (Detection/OCR만 표시) -->
                        <Expander IsExpanded="True" Margin="0,0,0,8"
                                  Visibility="{Binding IsBoundingBoxMode, Converter={StaticResource BoolToVis}, FallbackValue=Visible}">
                            <Expander.Header>
                                <Grid>
                                    <TextBlock Text="Labels" Style="{StaticResource SectionHeader}"/>
                                    <Button Content="Delete" HorizontalAlignment="Right"
                                            Command="{Binding DeleteSelectedLabelCommand}"
                                            Style="{StaticResource DangerButton}"
                                            Padding="8,1" FontSize="10"/>
                                </Grid>
                            </Expander.Header>
                            <ListBox ItemsSource="{Binding CurrentImage.Labels}"
                                     SelectedItem="{Binding SelectedLabel}"
                                     MaxHeight="200" Margin="0,6,0,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ClassName}"
                                                           FontWeight="Bold" FontSize="12"
                                                           Foreground="#4FC3F7"/>
                                                <TextBlock Text="{Binding BoundingBox, StringFormat=' [{0}]'}"
                                                           Foreground="#888" FontSize="10" Margin="6,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Transcription}"
                                                       Foreground="#AED581" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Expander>

                        <!-- Classification/Anomaly: Current Image Class Display -->
                        <Border Margin="0,0,0,8" Padding="10" CornerRadius="4"
                                Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsClassificationMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsAnomalyMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="Current Image Class" Style="{StaticResource SectionHeader}"/>
                                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,6,0,0"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding CurrentImageClass, FallbackValue='(미분류)'}"/>
                                            <Setter Property="Foreground" Value="#FFD700"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentImageClass}" Value="good">
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CurrentImageClass}" Value="defect">
                                                    <Setter Property="Foreground" Value="#F44336"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CurrentImageClass}" Value="{x:Null}">
                                                    <Setter Property="Text" Value="(미분류)"/>
                                                    <Setter Property="Foreground" Value="#888"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Selected Label Editor (Detection/OCR만 표시) -->
                        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1"
                                Padding="10" Margin="0,0,0,8" CornerRadius="3"
                                Visibility="{Binding SelectedLabel,
                                    Converter={StaticResource BoolToVis},
                                    FallbackValue=Collapsed}">
                            <StackPanel>
                                <TextBlock Text="Label Editor" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="Class:" Foreground="#999" FontSize="11" Margin="0,4,0,2"/>
                                <ComboBox ItemsSource="{Binding CurrentDataset.Classes}"
                                          SelectedItem="{Binding SelectedLabel.ClassName}"
                                          FontSize="12" Margin="0,0,0,8"/>

                                <TextBlock Text="Transcription:" Foreground="#999" FontSize="11" Margin="0,0,0,2"/>
                                <TextBox Text="{Binding SelectedLabel.Transcription, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" FontFamily="Consolas"
                                         Padding="6,4" Margin="0,0,0,4"/>

                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="Verified:" Foreground="#999" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <CheckBox IsChecked="{Binding SelectedLabel.IsVerified}"
                                              VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Export Section -->
                        <Expander IsExpanded="False" Margin="0,0,0,8">
                            <Expander.Header>
                                <TextBlock Text="Export" Style="{StaticResource SectionHeader}"/>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <Button Content="Auto Split (Train/Val)" Command="{Binding AutoSplitCommand}"
                                        Padding="8,6" FontSize="12" Margin="0,0,0,4"/>
                                <Button Content="Export for Training" Command="{Binding ExportForCurrentTaskCommand}"
                                        Style="{StaticResource SuccessButton}"
                                        Padding="8,6" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Foreground="#888" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap">
                                    <Run Text="Detection → YOLO format"/>
                                    <LineBreak/>
                                    <Run Text="Classification → ImageFolder format"/>
                                    <LineBreak/>
                                    <Run Text="Anomaly → MVTec format"/>
                                    <LineBreak/>
                                    <Run Text="OCR → PaddleOCR format"/>
                                </TextBlock>
                            </StackPanel>
                        </Expander>

                        <!-- Training Section -->
                        <Expander IsExpanded="False" Margin="0,0,0,8">
                            <Expander.Header>
                                <TextBlock Text="Training" Style="{StaticResource SectionHeader}"/>
                            </Expander.Header>
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="Python:" Foreground="#999" FontSize="11"/>
                                <TextBox Text="{Binding TrainingConfig.PythonPath, UpdateSourceTrigger=LostFocus}"
                                         FontSize="12" Margin="0,2,0,6"/>

                                <Grid>
                                    <TextBlock Text="Script:" Foreground="#999" FontSize="11"/>
                                    <Button Content="..." HorizontalAlignment="Right" Width="28"
                                            Command="{Binding SelectTrainingScriptCommand}"
                                            Padding="0,1" FontSize="10"/>
                                </Grid>
                                <TextBox Text="{Binding TrainingConfig.TrainingScriptPath, UpdateSourceTrigger=LostFocus}"
                                         FontSize="11" Margin="0,2,0,6"/>

                                <Grid>
                                    <TextBlock Text="Output:" Foreground="#999" FontSize="11"/>
                                    <Button Content="..." HorizontalAlignment="Right" Width="28"
                                            Command="{Binding SelectOutputDirCommand}"
                                            Padding="0,1" FontSize="10"/>
                                </Grid>
                                <TextBox Text="{Binding TrainingConfig.OutputDir, UpdateSourceTrigger=LostFocus}"
                                         FontSize="11" Margin="0,2,0,6"/>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,4,0">
                                        <TextBlock Text="Epochs:" Foreground="#999" FontSize="11"/>
                                        <TextBox Text="{Binding TrainingConfig.Epochs}"
                                                 FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                        <TextBlock Text="Batch Size:" Foreground="#999" FontSize="11"/>
                                        <TextBox Text="{Binding TrainingConfig.BatchSize}"
                                                 FontSize="12"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Start/Stop -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Start Training" Command="{Binding StartTrainingCommand}"
                                            Style="{StaticResource SuccessButton}"
                                            Padding="8,6" FontSize="12" Margin="0,0,4,0"/>
                                    <Button Grid.Column="1" Content="Stop"
                                            Command="{Binding StopTrainingCommand}"
                                            Style="{StaticResource DangerButton}"
                                            Padding="8,6" FontSize="12" Margin="4,0,0,0"/>
                                </Grid>

                                <!-- Progress -->
                                <ProgressBar Value="{Binding TrainingStatus.Progress, Mode=OneWay}"
                                             Minimum="0" Maximum="100"
                                             Margin="0,8,0,4"/>
                                <TextBlock Text="{Binding TrainingStatus.Message, Mode=OneWay}"
                                           Foreground="#AAA" FontSize="11"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Metrics -->
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Foreground="#888" FontSize="11">
                                        <Run Text="Loss: "/>
                                        <Run Text="{Binding TrainingStatus.Loss, Mode=OneWay, StringFormat='F4'}"
                                             Foreground="#FF9800"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#888" FontSize="11" Margin="16,0,0,0">
                                        <Run Text="Acc: "/>
                                        <Run Text="{Binding TrainingStatus.Accuracy, Mode=OneWay, StringFormat='P1'}"
                                             Foreground="#4CAF50"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Log -->
                                <ListBox ItemsSource="{Binding TrainingLog}" MaxHeight="150"
                                         Background="#1A1A1A" BorderBrush="#333" BorderThickness="1"
                                         FontSize="10" FontFamily="Consolas" Margin="0,6,0,0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="#888"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ Status Bar ═══ -->
        <Border Grid.Row="2" Background="#007ACC" Padding="8,2">
            <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="11"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
