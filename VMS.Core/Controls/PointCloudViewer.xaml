<UserControl x:Class="VMS.Core.Controls.PointCloudViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
             mc:Ignorable="d"
             Background="#1E1E1E">

    <UserControl.Resources>
        <Style x:Key="ViewerToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- 3D Viewport -->
        <hx:Viewport3DX x:Name="Viewport"
                         Background="Black"
                         ShowCoordinateSystem="True"
                         CoordinateSystemLabelForeground="White"
                         ShowFrameRate="False"
                         EnableDeferredRendering="False"
                         IsShadowMappingEnabled="False"
                         FXAALevel="None"
                         EnableSSAO="False"
                         EnableAutoOctreeUpdate="False"
                         IsRotationEnabled="False"
                         IsPanEnabled="False"
                         IsZoomEnabled="False"
                         IsInertiaEnabled="False"
                         IsMoveEnabled="False"
                         IsChangeFieldOfViewEnabled="False">

            <hx:Viewport3DX.Camera>
                <hx:PerspectiveCamera x:Name="MainCamera"
                                       Position="200,200,200"
                                       LookDirection="-200,-200,-200"
                                       UpDirection="0,1,0"
                                       FarPlaneDistance="10000"
                                       NearPlaneDistance="0.1"
                                       FieldOfView="45"/>
            </hx:Viewport3DX.Camera>

            <hx:AmbientLight3D Color="#404040"/>
            <hx:DirectionalLight3D Direction="-1,-1,-1" Color="White"/>

            <!-- Grid -->
            <hx:LineGeometryModel3D x:Name="GridLines" Color="Gray" Thickness="0.5"/>

            <!-- Axis Lines -->
            <hx:LineGeometryModel3D x:Name="AxisLines" Thickness="2.0"/>

            <!-- Point Cloud -->
            <hx:PointGeometryModel3D x:Name="PointCloudModel" Size="5,5" Color="White"/>

        </hx:Viewport3DX>

        <!-- Toolbar Overlay -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="6,6,0,0">
            <Button x:Name="BtnResetView" Content="Reset"
                    Click="BtnResetView_Click"
                    Style="{StaticResource ViewerToolbarButton}"/>
            <Button x:Name="BtnTopView" Content="Top"
                    Click="BtnTopView_Click"
                    Style="{StaticResource ViewerToolbarButton}"/>
            <Button x:Name="BtnFrontView" Content="Front"
                    Click="BtnFrontView_Click"
                    Style="{StaticResource ViewerToolbarButton}"/>
            <Button x:Name="BtnSideView" Content="Side"
                    Click="BtnSideView_Click"
                    Style="{StaticResource ViewerToolbarButton}"/>

            <TextBlock x:Name="PointCountText"
                       Foreground="#AAAAAA" FontSize="10"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
            <TextBlock x:Name="LodIndicator"
                       Foreground="#FF9800" FontSize="10"
                       VerticalAlignment="Center" Margin="6,0,0,0"/>
        </StackPanel>

        <!-- Color Bar (right side) -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Margin="0,30,6,10" Width="30"
                Background="#88000000" CornerRadius="3" Padding="3"
                x:Name="ColorBarPanel" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" x:Name="MaxValueLabel" Text=""
                           Foreground="White" FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,1"/>

                <Rectangle Grid.Row="1" Width="12" Margin="0,2" RadiusX="2" RadiusY="2">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFFF0000" Offset="0.0"/>
                            <GradientStop Color="#FFFFFF00" Offset="0.25"/>
                            <GradientStop Color="#FF00FF00" Offset="0.5"/>
                            <GradientStop Color="#FF00FFFF" Offset="0.75"/>
                            <GradientStop Color="#FF0000FF" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <TextBlock Grid.Row="2" x:Name="MinValueLabel" Text=""
                           Foreground="White" FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,1"/>
            </Grid>
        </Border>

        <!-- Status Bar (bottom) -->
        <Border x:Name="StatusBarPanel"
                HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                Background="#88000000" Padding="10,4"
                Visibility="Collapsed">
            <TextBlock x:Name="StatusBarText" Text=""
                       Foreground="#CCCCCC" FontSize="11"/>
        </Border>
    </Grid>
</UserControl>
