<UserControl x:Class="VMS.Core.Controls.DepthMapViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#1E1E1E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Color Bar (left side, Mech-Mind style) -->
        <Border Grid.Column="0" Background="#282828" Margin="4,4,0,4" CornerRadius="4" Padding="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" x:Name="MaxValueLabel" Text="--"
                           Foreground="White" FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,2"/>

                <Rectangle Grid.Row="1" Width="16" Margin="0,4" RadiusX="2" RadiusY="2">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFFF0000" Offset="0.0"/>
                            <GradientStop Color="#FFFFFF00" Offset="0.25"/>
                            <GradientStop Color="#FF00FF00" Offset="0.5"/>
                            <GradientStop Color="#FF00FFFF" Offset="0.75"/>
                            <GradientStop Color="#FF0000FF" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <TextBlock Grid.Row="2" x:Name="MinValueLabel" Text="--"
                           Foreground="White" FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,2"/>
            </Grid>
        </Border>

        <!-- Image Area -->
        <Border Grid.Column="1" ClipToBounds="True" Margin="4"
                Background="#1E1E1E">
            <Grid>
                <!-- Placeholder when no data or not organized -->
                <StackPanel x:Name="PlaceholderPanel"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="&#xE81C;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="48"
                               Foreground="#404040"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="PlaceholderText"
                               Text="No Depth Data"
                               Foreground="#606060"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Depth Map Image with zoom/pan -->
                <Image x:Name="DepthImage"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       Visibility="Collapsed"
                       RenderTransformOrigin="0,0">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ImageScale"/>
                            <TranslateTransform x:Name="ImageTranslate"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
            </Grid>
        </Border>
    </Grid>
</UserControl>
