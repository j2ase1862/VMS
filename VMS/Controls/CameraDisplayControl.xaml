<UserControl x:Class="VMS.Controls.CameraDisplayControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VMS.ViewModels"
             xmlns:controls="clr-namespace:VMS.Controls"
             d:DataContext="{d:DesignInstance vm:CameraViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Background="#2D2D2D"
            BorderBrush="{Binding StatusText, Converter={StaticResource StatusStateToColorConverter}}"
            BorderThickness="3"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- Header with camera name and drag handle -->
            <Border Grid.Row="0"
                    Background="#3D3D3D"
                    CornerRadius="6,6,0,0"
                    Cursor="SizeAll"
                    x:Name="DragHandle">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,0">
                        <TextBlock Text="&#xE722;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="#808080"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Name}"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Settings icon and Status indicator -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- Settings Button (toggles inline control box) -->
                        <Button x:Name="SettingsButton"
                                Command="{Binding ToggleControlBoxCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="6,4"
                                Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                ToolTip="Camera Settings">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="#B0B0B0"/>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#505050"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Status indicator -->
                        <Border Background="{Binding StatusText, Converter={StaticResource StatusStateToColorConverter}}"
                                CornerRadius="4"
                                Padding="8,2"
                                Margin="0,4,8,4">
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="11"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Camera 2D/3D view tabs -->
            <TabControl Grid.Row="1" Margin="4"
                        SelectedIndex="{Binding SelectedViewTab}"
                        Background="#1E1E1E"
                        BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="#2D2D2D"/>
                        <Setter Property="Foreground" Value="#808080"/>
                        <Setter Property="Padding" Value="8,2"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4,4,0,0"
                                            Padding="{TemplateBinding Padding}"
                                            Margin="1,0">
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#1E1E1E"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#3D3D3D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- 2D View Tab -->
                <TabItem Header="2D">
                    <Border Background="#1E1E1E">
                        <Grid>
                            <!-- Placeholder when no image -->
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding CurrentImage, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}">
                                <TextBlock Text="&#xE714;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="48"
                                           Foreground="#404040"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No Image"
                                           Foreground="#606060"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Actual camera image -->
                            <Image Source="{Binding CurrentImage}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- 3D View Tab -->
                <TabItem Header="3D">
                    <Border Background="#1E1E1E">
                        <Grid>
                            <!-- Placeholder when no point cloud -->
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding CurrentPointCloud, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}">
                                <TextBlock Text="&#xF158;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="48"
                                           Foreground="#404040"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No 3D Data"
                                           Foreground="#606060"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <!-- Point Cloud Viewer -->
                            <controls:PointCloudViewer
                                PointCloud="{Binding CurrentPointCloud}"
                                Visibility="{Binding CurrentPointCloud, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- Row 2: Tool Run Results DataGrid -->
            <Border Grid.Row="2" BorderBrush="#333333" BorderThickness="0,1,0,0"
                    Margin="4,0,4,2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="4,3,4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Run Results"
                                   Foreground="#FFD700" FontWeight="Bold" FontSize="11"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastExecutionTimeMs, StringFormat={}{0:F1} ms}"
                                   Foreground="#808080" FontSize="10"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ToolRunResults}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#444444"
                              Background="#1E1E1E"
                              Foreground="White"
                              BorderBrush="#555555"
                              BorderThickness="1"
                              RowBackground="#2D2D2D"
                              AlternatingRowBackground="#252526"
                              MaxHeight="120"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="False"
                              FontSize="11">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#3C3C3C"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="6,3"/>
                                <Setter Property="BorderBrush" Value="#555555"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Focusable" Value="False"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Height" Value="22"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#0078D4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tool Name"
                                                Binding="{Binding ToolName}"
                                                Width="*"
                                                MinWidth="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="4,2"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="P/F"
                                                Binding="{Binding Result}"
                                                Width="40">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="4,2"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Result}" Value="True">
                                                <Setter Property="Foreground" Value="#4EC94E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Result}" Value="False">
                                                <Setter Property="Foreground" Value="#FF6B6B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Result Value"
                                                Binding="{Binding ResultValue}"
                                                Width="2*"
                                                MinWidth="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="4,2"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Footer with Pass checkbox and info -->
            <Border Grid.Row="3" Background="#3D3D3D" CornerRadius="0,0,6,6">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Pass checkbox -->
                    <CheckBox Grid.Column="0"
                              IsChecked="{Binding IsPassed}"
                              VerticalAlignment="Center">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border x:Name="CheckBorder"
                                                        Width="20" Height="20"
                                                        Background="#404040"
                                                        BorderBrush="#606060"
                                                        BorderThickness="1"
                                                        CornerRadius="4">
                                                    <TextBlock x:Name="CheckMark"
                                                               Text="&#xE73E;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="14"
                                                               Foreground="LimeGreen"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="Collapsed"/>
                                                </Border>
                                                <TextBlock Text="Pass"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"
                                                           Margin="6,0,0,0"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="CheckBorder" Property="Background" Value="#2D5A2D"/>
                                                    <Setter TargetName="CheckBorder" Property="BorderBrush" Value="LimeGreen"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#808080"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- Camera info -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding IpAddress}"
                               Foreground="#808080"
                               FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <!-- Inspection count -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="Count: " Foreground="#808080" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding InspectionCount}" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Resize grip (bottom-right corner) -->
            <Thumb Grid.Row="1" Grid.RowSpan="3"
                   Width="16" Height="16"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Cursor="SizeNWSE"
                   x:Name="ResizeGrip">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Path Data="M 0,16 L 16,0 M 5,16 L 16,5 M 10,16 L 16,10"
                                  Stroke="#606060"
                                  StrokeThickness="1"/>
                        </Grid>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- Inline Control Box Overlay -->
            <Border Grid.Row="0" Grid.RowSpan="4"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Width="280"
                    Margin="4,34,4,0"
                    Panel.ZIndex="10"
                    Background="#F0282828"
                    BorderBrush="#505050"
                    BorderThickness="1"
                    CornerRadius="0,0,6,6"
                    Padding="12,8"
                    RenderTransformOrigin="0.5,0"
                    Opacity="0">
                <Border.RenderTransform>
                    <ScaleTransform ScaleY="0"/>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="IsHitTestVisible" Value="False"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsControlBoxOpen}" Value="True">
                                <Setter Property="IsHitTestVisible" Value="True"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="0" Duration="0:0:0.12">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <StackPanel>
                    <!-- Step selector -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Step:" Foreground="#B0B0B0" VerticalAlignment="Center" FontSize="11"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Steps}"
                                  SelectedItem="{Binding SelectedStep}"
                                  DisplayMemberPath="Name"
                                  Background="#404040"
                                  Foreground="White"
                                  BorderThickness="0"
                                  Padding="6,4">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="Black"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </Grid>

                    <!-- Exposure -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Exposure:" Foreground="#B0B0B0" VerticalAlignment="Center" FontSize="11"/>
                        <Slider Grid.Column="1"
                                Value="{Binding Exposure}"
                                Minimum="100" Maximum="100000"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Exposure, StringFormat=N0}"
                                   Foreground="White" FontSize="11"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Gain -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Gain:" Foreground="#B0B0B0" VerticalAlignment="Center" FontSize="11"/>
                        <Slider Grid.Column="1"
                                Value="{Binding Gain}"
                                Minimum="0" Maximum="24"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Gain, StringFormat=N1}"
                                   Foreground="White" FontSize="11"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Action buttons row 1: Grab / Open / Inspect -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Command="{Binding GrabCommand}"
                                Style="{StaticResource ModernButton}"
                                Padding="8,4" Margin="0,0,2,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="Grab" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1"
                                Command="{Binding OpenImageCommand}"
                                Style="{StaticResource ModernButton}"
                                Padding="8,4" Margin="2,0,2,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="Open" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2"
                                Command="{Binding ManualInspectCommand}"
                                Style="{StaticResource ModernButton}"
                                Padding="8,4" Margin="2,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="Inspect" FontSize="11"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Action buttons row 2: Save / Close -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Command="{Binding SaveSettingsCommand}"
                                Background="#4CAF50"
                                Style="{StaticResource ModernButton}"
                                Padding="8,4" Margin="0,0,2,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0"/>
                                <TextBlock Text="Save" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1"
                                Command="{Binding CloseControlBoxCommand}"
                                Background="#606060"
                                Style="{StaticResource ModernButton}"
                                Padding="8,4" Margin="2,0,0,0">
                            <TextBlock Text="Close" FontSize="11"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
