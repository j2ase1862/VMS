<Window x:Class="VMS.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:VMS.Models"
        Title="User Management"
        Width="720" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- User List -->
        <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="8" Padding="12" Margin="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Users"
                           FontWeight="SemiBold" Foreground="#2196F3"
                           FontSize="16" Margin="0,0,0,8"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="#2D2D2D"
                          Foreground="White"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#3D3D3D"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          RowBackground="#2D2D2D"
                          AlternatingRowBackground="#333333">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#3D3D3D"/>
                            <Setter Property="Foreground" Value="#B0B0B0"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="100"/>
                        <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="120"/>
                        <DataGridTextColumn Header="Grade" Binding="{Binding Grade}" Width="80"/>
                        <DataGridTextColumn Header="Last Login" Binding="{Binding LastLoginAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Right Panel: Add / Edit -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Add New User Section -->
                <Border Background="#2D2D2D" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Add New User"
                                   FontWeight="SemiBold" Foreground="#4CAF50"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Username" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#404040" Foreground="White" BorderBrush="#3D3D3D"
                                 Padding="6,4" Margin="0,0,0,6" CaretBrush="White"/>

                        <TextBlock Text="Display Name" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding NewDisplayName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#404040" Foreground="White" BorderBrush="#3D3D3D"
                                 Padding="6,4" Margin="0,0,0,6" CaretBrush="White"/>

                        <TextBlock Text="Password" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,2"/>
                        <PasswordBox x:Name="NewPasswordBox"
                                     Background="#404040" Foreground="White" BorderBrush="#3D3D3D"
                                     Padding="6,4" Margin="0,0,0,6" CaretBrush="White"/>

                        <TextBlock Text="Grade" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{Binding GradeValues}"
                                  SelectedItem="{Binding NewGrade}"
                                  Background="White" Foreground="Black" BorderBrush="#3D3D3D"
                                  Padding="6,4" Margin="0,0,0,8"/>

                        <Button Content="Add User"
                                Command="{Binding AddUserCommand}"
                                Click="AddUser_Click"
                                Style="{StaticResource ModernButton}"
                                Background="#4CAF50"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Edit Selected User Section -->
                <Border Background="#2D2D2D" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Edit Selected User"
                                   FontWeight="SemiBold" Foreground="#FF9800"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Display Name" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding SelectedUser.DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#404040" Foreground="White" BorderBrush="#3D3D3D"
                                 Padding="6,4" Margin="0,0,0,6" CaretBrush="White"
                                 IsEnabled="{Binding SelectedUser, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <TextBlock Text="Grade" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox ItemsSource="{Binding GradeValues}"
                                  SelectedItem="{Binding SelectedUser.Grade}"
                                  Background="White" Foreground="Black" BorderBrush="#3D3D3D"
                                  Padding="6,4" Margin="0,0,0,8"
                                  IsEnabled="{Binding SelectedUser, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <Button Content="Save Changes"
                                Command="{Binding SaveUserCommand}"
                                Style="{StaticResource ModernButton}"
                                Background="#FF9800"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,4"/>

                        <!-- Change Password -->
                        <TextBlock Text="New Password" Foreground="#B0B0B0" FontSize="11" Margin="0,8,0,2"/>
                        <PasswordBox x:Name="ChangePasswordBox"
                                     Background="#404040" Foreground="White" BorderBrush="#3D3D3D"
                                     Padding="6,4" Margin="0,0,0,6" CaretBrush="White"/>

                        <Button Content="Change Password"
                                Command="{Binding ChangePasswordCommand}"
                                Click="ChangePassword_Click"
                                Style="{StaticResource ModernButton}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"/>

                        <!-- Delete -->
                        <Button Content="Delete User"
                                Command="{Binding DeleteUserCommand}"
                                Style="{StaticResource ModernButton}"
                                Background="#F44336"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#B0B0B0"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
