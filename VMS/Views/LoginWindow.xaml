<Window x:Class="VMS.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="380" Height="500"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="12" Margin="16" Background="#1E1E1E">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.6" Color="Black"/>
        </Border.Effect>

        <Grid Margin="32,24,32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Logo -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,24">
                <TextBlock Text="&#xE774;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="48"
                           Foreground="#2196F3"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="BODA Vision System"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
                <TextBlock Text="Login"
                           FontSize="13"
                           Foreground="#808080"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Username -->
            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock Text="Username"
                           Foreground="#B0B0B0"
                           FontSize="12"
                           Margin="0,0,0,4"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Background="#2D2D2D"
                         Foreground="White"
                         BorderBrush="#3D3D3D"
                         BorderThickness="1"
                         Padding="10,8"
                         FontSize="14"
                         CaretBrush="White"/>
            </StackPanel>

            <!-- Password -->
            <StackPanel Grid.Row="2" Margin="0,0,0,16">
                <TextBlock Text="Password"
                           Foreground="#B0B0B0"
                           FontSize="12"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                             Background="#2D2D2D"
                             Foreground="White"
                             BorderBrush="#3D3D3D"
                             BorderThickness="1"
                             Padding="10,8"
                             FontSize="14"
                             CaretBrush="White"
                             KeyDown="PasswordBox_KeyDown"/>
            </StackPanel>

            <!-- Error Message -->
            <TextBlock Grid.Row="3"
                       Text="{Binding ErrorMessage}"
                       Foreground="#F44336"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

            <!-- Login Button -->
            <Button Grid.Row="4"
                    Content="Login"
                    Command="{Binding LoginCommand}"
                    Background="#2196F3"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Padding="0,12"
                    Cursor="Hand"
                    BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Close button -->
            <Button Grid.Row="5"
                    Content="Exit"
                    Click="CloseButton_Click"
                    Background="Transparent"
                    Foreground="#808080"
                    FontSize="12"
                    Padding="0,8"
                    Cursor="Hand"
                    BorderThickness="0"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F44336"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
