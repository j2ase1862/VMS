<Window x:Class="VMS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VMS.Controls"
        Title="{Binding ApplicationTitle}"
        WindowState="Maximized"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Panel animation -->
        <Storyboard x:Key="OpenPanel">
            <DoubleAnimation Storyboard.TargetName="SidePanel"
                             Storyboard.TargetProperty="Width"
                             To="320" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="ClosePanel">
            <DoubleAnimation Storyboard.TargetName="SidePanel"
                             Storyboard.TargetProperty="Width"
                             To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="ToggleButton.Checked" SourceName="PanelToggle">
            <BeginStoryboard Storyboard="{StaticResource OpenPanel}"/>
        </EventTrigger>
        <EventTrigger RoutedEvent="ToggleButton.Unchecked" SourceName="PanelToggle">
            <BeginStoryboard Storyboard="{StaticResource ClosePanel}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Row 0: Header Bar + User Info -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#2D2D2D">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0">
                    <TextBlock Text="&#xE774;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="24"
                               Foreground="#2196F3"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ApplicationTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Center: Recipe info and controls -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Border Background="#3D3D3D" CornerRadius="4" Padding="12,4" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE82D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="#808080"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentRecipeName}"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Grab (single shot) -->
                    <Button Background="#2196F3"
                            Foreground="White"
                            Command="{Binding GrabCommand}"
                            IsEnabled="{Binding CanStartStop}"
                            Visibility="{Binding IsLiveMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                            Style="{StaticResource ModernButton}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Grab"/>
                        </StackPanel>
                    </Button>

                    <!-- Live Start/Stop buttons -->
                    <Button Background="#4CAF50"
                            Foreground="White"
                            Command="{Binding StartLiveCommand}"
                            IsEnabled="{Binding CanStartStop}"
                            Visibility="{Binding IsLiveMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                            Style="{StaticResource ModernButton}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Live Start"/>
                        </StackPanel>
                    </Button>

                    <Button Background="#FF9800"
                            Foreground="White"
                            Command="{Binding StopLiveCommand}"
                            Visibility="{Binding IsLiveMode, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource ModernButton}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Live Stop"/>
                        </StackPanel>
                    </Button>

                    <!-- Start/Stop buttons -->
                    <Button Style="{StaticResource ModernButton}"
                            Command="{Binding StartInspectionCommand}"
                            IsEnabled="{Binding CanStartStop}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Start"/>
                        </StackPanel>
                    </Button>

                    <Button Background="#F44336"
                            Foreground="White"
                            Command="{Binding StopInspectionCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource ModernButton}"
                            Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Stop"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- User Info (clickable for user switch) -->
                <Border Grid.Column="2" Background="#3D3D3D" CornerRadius="4"
                        Padding="8,4" Margin="0,8,8,8"
                        Cursor="Hand"
                        Visibility="{Binding CurrentUserDisplay, Converter={StaticResource NullToVisibilityConverter}}">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding SwitchUserCommand}"/>
                    </Border.InputBindings>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE77B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="{Binding CurrentUserGrade, Converter={StaticResource UserGradeToColorConverter}}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentUserDisplay}"
                                   Foreground="White"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Right: Toolbar buttons -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,8,0">
                    <!-- User Management (Admin only) -->
                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding OpenUserManagementCommand}"
                            IsEnabled="{Binding CanManageUsers}"
                            ToolTip="User Management"
                            Visibility="{Binding CanManageUsers, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="&#xE748;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"/>
                    </Button>

                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding SaveLayoutCommand}"
                            ToolTip="Save Layout">
                        <TextBlock Text="&#xE74E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"/>
                    </Button>

                    <ToggleButton x:Name="PanelToggle"
                                  IsChecked="{Binding IsSidePanelOpen, Mode=TwoWay}"
                                  Style="{StaticResource IconToggleButton}"
                                  ToolTip="Settings Panel"
                                  Margin="4,0">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"/>
                    </ToggleButton>

                    <Rectangle Width="1" Fill="#404040" Margin="8,8"/>

                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding ExitApplicationCommand}"
                            ToolTip="Exit">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Foreground="#F44336"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Row 1: Dashboard KPI Strip (always visible) -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#252525">
            <Grid Margin="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- TACT TIME -->
                <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="6" Padding="12,6" Margin="2,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="TACT TIME" Foreground="#808080" FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock FontSize="24" FontWeight="Bold" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dashboard.IsTactTimeExceeded}" Value="True">
                                            <Setter Property="Foreground" Value="#F44336"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding Dashboard.TactTime, StringFormat={}{0:F2}}"/><Run Text="s" FontSize="12"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- YIELD -->
                <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="6" Padding="12,6" Margin="2,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="YIELD" Foreground="#808080" FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock FontSize="24" FontWeight="Bold" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dashboard.Yield, Converter={StaticResource CountToVisibilityConverter}}" Value="Collapsed">
                                            <Setter Property="Foreground" Value="#FF9800"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding Dashboard.Yield, StringFormat={}{0:F1}}"/><Run Text="%" FontSize="12"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- TOTAL -->
                <Border Grid.Column="2" Background="#2D2D2D" CornerRadius="6" Padding="12,6" Margin="2,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="TOTAL" Foreground="#808080" FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Dashboard.TotalCount}"
                                   FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- OK -->
                <Border Grid.Column="3" Background="#2D2D2D" CornerRadius="6" Padding="12,6" Margin="2,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="OK" Foreground="#808080" FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Dashboard.OkCount}"
                                   FontSize="24" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- NG -->
                <Border Grid.Column="4" Background="#2D2D2D" CornerRadius="6" Padding="12,6" Margin="2,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="NG" Foreground="#808080" FontSize="10" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Dashboard.NgCount}"
                                   FontSize="24" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Reset button -->
                <Button Grid.Column="5" Style="{StaticResource IconButton}"
                        Command="{Binding ResetDashboardCommand}"
                        ToolTip="Reset Statistics"
                        VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="&#xE72C;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14" Foreground="#808080"/>
                </Button>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Row 2: Main Content Area + NG History Sidebar -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Camera Display Area -->
            <Canvas x:Name="CameraCanvas"
                    Grid.Column="0"
                    Background="#1E1E1E"
                    ClipToBounds="True">
                <ItemsControl ItemsSource="{Binding Cameras}"
                              Width="{Binding ActualWidth, ElementName=CameraCanvas}"
                              Height="{Binding ActualHeight, ElementName=CameraCanvas}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:CameraDisplayControl
                                Width="{Binding Width}"
                                Height="{Binding Height}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Alignment guide lines overlay -->
                <Canvas x:Name="AlignmentGuideCanvas"
                        IsHitTestVisible="False"
                        Width="{Binding ActualWidth, ElementName=CameraCanvas}"
                        Height="{Binding ActualHeight, ElementName=CameraCanvas}"/>
            </Canvas>

            <!-- NG Image History Sidebar (always visible) -->
            <Border Grid.Column="1" Width="120" Background="#252525"
                    BorderBrush="#3D3D3D" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="NG History"
                               Foreground="#F44336" FontWeight="SemiBold"
                               FontSize="11" Margin="8,6"
                               HorizontalAlignment="Center"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Dashboard.NgImageHistory}"
                             SelectedItem="{Binding SelectedNgImage}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2D2D2D" CornerRadius="4"
                                        Margin="4,2" Padding="2">
                                    <StackPanel>
                                        <Image Source="{Binding Thumbnail}"
                                               Width="100" Height="75"
                                               Stretch="Uniform"/>
                                        <TextBlock Text="{Binding CameraName}"
                                                   Foreground="#B0B0B0" FontSize="9"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}"
                                                   Foreground="#808080" FontSize="8"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Sliding Side Panel -->
            <Border x:Name="SidePanel"
                    Grid.Column="2"
                    Width="0"
                    Background="#2D2D2D"
                    BorderBrush="#3D3D3D"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <!-- Panel Header -->
                        <TextBlock Text="Settings"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,0,0,16"/>

                        <!-- Recipe Section -->
                        <Border Background="#3D3D3D"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Recipe"
                                           FontWeight="SemiBold"
                                           Foreground="#2196F3"
                                           Margin="0,0,0,12"/>

                                <!-- Current Recipe Display -->
                                <Border Background="#404040"
                                        CornerRadius="4"
                                        Padding="8"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CurrentRecipeName}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CurrentRecipe.Version, StringFormat='v{0}', FallbackValue=''}"
                                                   Foreground="#808080"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <!-- Recipe List -->
                                <TextBlock Text="Available Recipes"
                                           Foreground="#B0B0B0"
                                           FontSize="11"
                                           Margin="0,0,0,4"/>
                                <ListBox ItemsSource="{Binding RecipeList}"
                                         SelectedItem="{Binding SelectedRecipeInfo}"
                                         Background="#404040"
                                         BorderThickness="0"
                                         MaxHeight="120"
                                         Margin="0,0,0,8">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4,2">
                                                <TextBlock Text="{Binding Name}" Foreground="White"/>
                                                <TextBlock Text="{Binding ModifiedAt, StringFormat='Modified: {0:yyyy-MM-dd}'}"
                                                           Foreground="#808080" FontSize="10"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Recipe Buttons -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Command="{Binding LoadRecipeCommand}"
                                            Style="{StaticResource ModernButton}"
                                            Margin="0,0,4,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8E5;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="12"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="Load"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Command="{Binding NewRecipeCommand}"
                                            IsEnabled="{Binding CanEditRecipe}"
                                            Style="{StaticResource ModernButton}"
                                            Margin="4,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE710;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="12"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="New"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Command="{Binding SaveCurrentRecipeCommand}"
                                            IsEnabled="{Binding CanEditRecipe}"
                                            Style="{StaticResource ModernButton}"
                                            Margin="0,0,2,0"
                                            ToolTip="Save Recipe">
                                        <TextBlock Text="&#xE74E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"/>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Command="{Binding ExportRecipeCommand}"
                                            Style="{StaticResource ModernButton}"
                                            Margin="2,0,2,0"
                                            ToolTip="Export Recipe">
                                        <TextBlock Text="&#xEDE1;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"/>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Command="{Binding ImportRecipeCommand}"
                                            IsEnabled="{Binding CanEditRecipe}"
                                            Style="{StaticResource ModernButton}"
                                            Margin="2,0,0,0"
                                            ToolTip="Import Recipe">
                                        <TextBlock Text="&#xE8B5;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- External Tools Section -->
                        <Border Background="#3D3D3D"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="External Tools"
                                           FontWeight="SemiBold"
                                           Foreground="#2196F3"
                                           Margin="0,0,0,12"/>

                                <Button Command="{Binding LaunchVisionToolSetupCommand}"
                                        IsEnabled="{Binding CanLaunchVisionSetup}"
                                        Style="{StaticResource ModernButton}"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7AC;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="Vision Tool Setup"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding LaunchSetupCommand}"
                                        IsEnabled="{Binding CanLaunchAppSetup}"
                                        Background="#4CAF50"
                                        Style="{StaticResource ModernButton}"
                                        HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE713;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="System Setup"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Statistics Section -->
                        <Border Background="#3D3D3D"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Statistics"
                                           FontWeight="SemiBold"
                                           Foreground="#2196F3"
                                           Margin="0,0,0,12"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Total" Foreground="#B0B0B0"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalInspections}" Foreground="White" FontWeight="Bold"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Pass" Foreground="#4CAF50" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalPass}" Foreground="#4CAF50" FontWeight="Bold" Margin="0,4,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Fail" Foreground="#F44336" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TotalFail}" Foreground="#F44336" FontWeight="Bold" Margin="0,4,0,0"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Pass Rate" Foreground="#B0B0B0" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{Binding PassRate, StringFormat={}{0:N1}%}"
                                               Foreground="White" FontWeight="Bold" Margin="0,8,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Row 3: System Log Viewer -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#1A1A1A"
                BorderBrush="#3D3D3D" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Log Header -->
                <Border Grid.Row="0" Background="#252525" Padding="8,4">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE756;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Foreground="#808080"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="System Log"
                                       Foreground="#B0B0B0"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource IconButton}"
                                Command="{Binding ClearLogCommand}"
                                ToolTip="Clear Log"
                                Padding="4">
                            <TextBlock Text="&#xE74D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11" Foreground="#808080"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Log List -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding LogService.LogEntries}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="True"
                         VirtualizingPanel.IsVirtualizing="True"
                         x:Name="LogListBox">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontFamily="Consolas" FontSize="11" Margin="4,1">
                                <Run Text="{Binding Timestamp, StringFormat='[HH:mm:ss]'}" Foreground="#606060"/>
                                <Run Text="{Binding Source, StringFormat='[{0}]'}" Foreground="#808080"/>
                                <Run Text="{Binding Message}" Foreground="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Row 4: Status Bar — Equipment Connection Status -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="#2D2D2D">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- [0] System Status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding IsRunning, Converter={StaticResource BoolToColorConverter}}"
                             Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding SystemStatus}"
                               Foreground="#B0B0B0" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- [1] Separator -->
                <Rectangle Grid.Column="1" Width="1" Fill="#404040" Margin="10,6"/>

                <!-- [2] Camera Status -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Foreground="#B0B0B0"
                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#555555"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CameraConnectionStatus}" Value="All">
                                        <Setter Property="Fill" Value="#4CAF50"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CameraConnectionStatus}" Value="Partial">
                                        <Setter Property="Fill" Value="#FF9800"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CameraConnectionStatus}" Value="None">
                                        <Setter Property="Fill" Value="#F44336"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Foreground="#B0B0B0" FontSize="12" VerticalAlignment="Center">
                        <Run Text="CAM"/>
                        <Run Text="{Binding ConnectedCameraCount, Mode=OneWay}"/>/<Run Text="{Binding TotalCameraCount, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <!-- [3] Separator -->
                <Rectangle Grid.Column="3" Width="1" Fill="#404040" Margin="10,6"/>

                <!-- [4] PLC Status -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Foreground="#B0B0B0"
                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#555555"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsPlcConfigured}" Value="True"/>
                                            <Condition Binding="{Binding IsPlcConnected}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Fill" Value="#4CAF50"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsPlcConfigured}" Value="True"/>
                                            <Condition Binding="{Binding IsPlcConnected}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Fill" Value="#F44336"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="12" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#B0B0B0"/>
                                <Setter Property="Text" Value="PLC N/A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlcConfigured}" Value="True">
                                        <Setter Property="Text" Value="{Binding PlcVendorName}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding PlcIpAddress}" Foreground="#808080" FontSize="11"
                               VerticalAlignment="Center" Margin="6,0,0,0"
                               Visibility="{Binding IsPlcConfigured, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>

                <!-- [5] Spacer -->

                <!-- [6] Robot (placeholder) -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets"
                               FontSize="13" Foreground="#808080"
                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Ellipse Width="8" Height="8" Fill="#555555" Margin="0,0,5,0"/>
                    <TextBlock Text="ROBOT N/A" Foreground="#808080" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
