<Window x:Class="VMS.AppSetup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:VMS.AppSetup.Converters"
        mc:Ignorable="d"
        Title="BODA Vision System Setup"
        Width="860" Height="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Window.Resources>
        <converters:PageToVisibilityConverter x:Key="PageConverter"/>
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <!-- Button Styles -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1084D8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#555555"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#3E3E42"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#505054"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2D2D30"/>
                    <Setter Property="Foreground" Value="#555555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1084D8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding PageTitle}"
                               Foreground="#FFD700" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="{Binding PageDescription}"
                               Foreground="#AAAAAA" FontSize="12" Margin="0,8,0,0"
                               TextWrapping="Wrap" MaxWidth="550" HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Page Indicator -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <TextBlock Text="Step " Foreground="#888888" FontSize="14"/>
                    <TextBlock Text="{Binding CurrentPage}" Foreground="#FFD700" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text=" of 4" Foreground="#888888" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Page Content -->
        <Border Grid.Row="1" Background="#1E1E1E" Padding="30">
            <Grid>
                <!-- Page 1: Welcome -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageConverter}, ConverterParameter=1}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="BODA" FontSize="72" Foreground="#0078D4"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Vision System" FontSize="28" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,-5,0,0"/>
                        <TextBlock Text="Machine Vision Configuration Wizard" FontSize="14"
                                   Foreground="#888888" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Page 2: Application Settings -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageConverter}, ConverterParameter=2}">
                    <StackPanel MaxWidth="500" VerticalAlignment="Top">
                        <TextBlock Text="Application Name" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding ApplicationName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}" Margin="0,0,0,20"/>

                        <TextBlock Text="System IP Address" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding SystemIpAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}"/>

                        <TextBlock Text="This is the IP address of the machine vision system PC."
                                   Foreground="#666666" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Page 3: Camera Configuration -->
                <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageConverter}, ConverterParameter=3}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Mode Selection -->
                    <Border Grid.Row="0" Background="#252526" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Live Mode (Scan Network)" GroupName="CameraMode"
                                         IsChecked="{Binding CameraMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Live}"
                                         Foreground="White" FontSize="13" Margin="0,0,40,0"
                                         VerticalContentAlignment="Center"/>
                            <RadioButton Content="Virtual Mode (Manual Setup)" GroupName="CameraMode"
                                         IsChecked="{Binding CameraMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Virtual}"
                                         Foreground="White" FontSize="13"
                                         VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Controls -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="+ Add Camera" Command="{Binding AddCameraCommand}"
                                Style="{StaticResource SmallButtonStyle}" Margin="0,0,10,0"/>
                        <Button Content="Scan Network" Command="{Binding ScanForCamerasCommand}"
                                Style="{StaticResource SmallButtonStyle}" Background="#3E3E42"/>
                    </StackPanel>

                    <!-- Camera List -->
                    <Border Grid.Row="2" Background="#252526" CornerRadius="6" Padding="10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Cameras}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#2D2D30" BorderBrush="#3E3E42" BorderThickness="1"
                                                CornerRadius="6" Padding="15,12" Margin="0,4">
                                            <StackPanel>
                                                <!-- Row 1: Basic Info -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Enable Checkbox -->
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                              VerticalAlignment="Center" Margin="0,0,15,0"
                                                              ToolTip="Enable/Disable Camera"/>

                                                    <!-- Camera Info -->
                                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:"
                                                                   Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                 Background="#3E3E42" Foreground="White"
                                                                 BorderBrush="#555555" BorderThickness="1"
                                                                 Padding="6,4" FontSize="12" Margin="0,0,0,6"/>

                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="IP:"
                                                                   Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                                 Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                                                                 Background="#3E3E42" Foreground="White"
                                                                 BorderBrush="#555555" BorderThickness="1"
                                                                 Padding="6,4" FontSize="12"/>
                                                    </Grid>

                                                    <!-- Camera Type -->
                                                    <ComboBox Grid.Column="2"
                                                              ItemsSource="{Binding DataContext.CameraTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding CameraType}"
                                                              Width="110" Margin="10,0"
                                                              VerticalAlignment="Center"
                                                              Style="{StaticResource ComboStyle}"
                                                              Padding="8,6" FontSize="12"/>

                                                    <!-- Manufacturer -->
                                                    <ComboBox Grid.Column="3"
                                                              ItemsSource="{Binding DataContext.CameraManufacturers, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedItem="{Binding Manufacturer}"
                                                              Width="110" Margin="0,0,10,0"
                                                              VerticalAlignment="Center"
                                                              Style="{StaticResource ComboStyle}"
                                                              Padding="8,6" FontSize="12"/>

                                                    <!-- Remove Button -->
                                                    <Button Grid.Column="4" Content="✕"
                                                            Command="{Binding DataContext.RemoveCameraCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="#D32F2F" Foreground="White"
                                                            Width="32" Height="32" FontSize="14"
                                                            BorderThickness="0" Cursor="Hand"
                                                            ToolTip="Remove Camera">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="4">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>

                                                <!-- Row 2: Area Scan Parameters -->
                                                <Border Background="#252526" CornerRadius="4" Padding="10,8" Margin="0,8,0,0"
                                                        Visibility="{Binding IsAreaScan, Converter={StaticResource BoolToVisConverter}}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Exposure (μs)" Foreground="#888888" FontSize="11" Margin="0,0,0,3"/>
                                                            <TextBox Text="{Binding Exposure, UpdateSourceTrigger=PropertyChanged}"
                                                                     Background="#3E3E42" Foreground="White"
                                                                     BorderBrush="#555555" BorderThickness="1"
                                                                     Padding="6,4" FontSize="12"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Gain" Foreground="#888888" FontSize="11" Margin="0,0,0,3"/>
                                                            <TextBox Text="{Binding Gain, UpdateSourceTrigger=PropertyChanged}"
                                                                     Background="#3E3E42" Foreground="White"
                                                                     BorderBrush="#555555" BorderThickness="1"
                                                                     Padding="6,4" FontSize="12"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Row 3: Line Scan Parameters -->
                                                <Border Background="#252526" CornerRadius="4" Padding="10,8" Margin="0,8,0,0"
                                                        Visibility="{Binding IsLineScan, Converter={StaticResource BoolToVisConverter}}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Trigger" Foreground="#888888" FontSize="11" Margin="0,0,0,3"/>
                                                            <ComboBox ItemsSource="{Binding DataContext.TriggerSources, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      SelectedItem="{Binding TriggerSource}"
                                                                      Style="{StaticResource ComboStyle}"
                                                                      Padding="6,4" FontSize="12"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Line Rate (Hz)" Foreground="#888888" FontSize="11" Margin="0,0,0,3"/>
                                                            <TextBox Text="{Binding LineRate, UpdateSourceTrigger=PropertyChanged}"
                                                                     Background="#3E3E42" Foreground="White"
                                                                     BorderBrush="#555555" BorderThickness="1"
                                                                     Padding="6,4" FontSize="12"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="4">
                                                            <TextBlock Text="Scan Length" Foreground="#888888" FontSize="11" Margin="0,0,0,3"/>
                                                            <TextBox Text="{Binding ScanLength, UpdateSourceTrigger=PropertyChanged}"
                                                                     Background="#3E3E42" Foreground="White"
                                                                     BorderBrush="#555555" BorderThickness="1"
                                                                     Padding="6,4" FontSize="12"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="6"
                                                                    Visibility="{Binding ShowEncoderResolution, Converter={StaticResource BoolToVisConverter}}">
                                                            <TextBlock Text="Encoder Res (P/mm)" Foreground="#888888" FontSize="11" Margin="0,0,0,3"/>
                                                            <TextBox Text="{Binding EncoderResolution, UpdateSourceTrigger=PropertyChanged}"
                                                                     Background="#3E3E42" Foreground="White"
                                                                     BorderBrush="#555555" BorderThickness="1"
                                                                     Padding="6,4" FontSize="12"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Row 4: 3D Camera Parameters -->
                                                <Border Background="#252526" CornerRadius="4" Padding="10,8" Margin="0,8,0,0"
                                                        Visibility="{Binding Is3DCamera, Converter={StaticResource BoolToVisConverter}}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Capture Mode" Foreground="#888888" FontSize="11" Margin="0,0,0,3"/>
                                                            <ComboBox ItemsSource="{Binding DataContext.CaptureModes3D, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      SelectedItem="{Binding CaptureMode}"
                                                                      Style="{StaticResource ComboStyle}"
                                                                      Padding="6,4" FontSize="12"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Filter Strength" Foreground="#888888" FontSize="11" Margin="0,0,0,3"/>
                                                            <TextBox Text="{Binding FilterStrength, UpdateSourceTrigger=PropertyChanged}"
                                                                     Background="#3E3E42" Foreground="White"
                                                                     BorderBrush="#555555" BorderThickness="1"
                                                                     Padding="6,4" FontSize="12"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="4">
                                                            <TextBlock Text="Z Min (mm)" Foreground="#888888" FontSize="11" Margin="0,0,0,3"/>
                                                            <TextBox Text="{Binding ZRangeMin, UpdateSourceTrigger=PropertyChanged}"
                                                                     Background="#3E3E42" Foreground="White"
                                                                     BorderBrush="#555555" BorderThickness="1"
                                                                     Padding="6,4" FontSize="12"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="6">
                                                            <TextBlock Text="Z Max (mm)" Foreground="#888888" FontSize="11" Margin="0,0,0,3"/>
                                                            <TextBox Text="{Binding ZRangeMax, UpdateSourceTrigger=PropertyChanged}"
                                                                     Background="#3E3E42" Foreground="White"
                                                                     BorderBrush="#555555" BorderThickness="1"
                                                                     Padding="6,4" FontSize="12"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Page 4: PLC Configuration -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding CurrentPage, Converter={StaticResource PageConverter}, ConverterParameter=4}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Left Column: PLC Vendor + Performance & Stability -->
                        <StackPanel Grid.Column="0" Grid.RowSpan="2" Margin="0,0,12,0">

                            <!-- PLC Vendor Selection -->
                            <TextBlock Text="PLC Vendor" Style="{StaticResource LabelStyle}"/>
                            <Border Background="#252526" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                                <StackPanel>
                                    <RadioButton Content="Mitsubishi" GroupName="PlcVendor"
                                                 IsChecked="{Binding SelectedPlcVendor, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Mitsubishi}"
                                                 Foreground="White" FontSize="13" Margin="5"/>
                                    <RadioButton Content="Siemens" GroupName="PlcVendor"
                                                 IsChecked="{Binding SelectedPlcVendor, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Siemens}"
                                                 Foreground="White" FontSize="13" Margin="5"/>
                                    <RadioButton Content="LS Electric" GroupName="PlcVendor"
                                                 IsChecked="{Binding SelectedPlcVendor, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=LS}"
                                                 Foreground="White" FontSize="13" Margin="5"/>
                                    <RadioButton Content="Omron" GroupName="PlcVendor"
                                                 IsChecked="{Binding SelectedPlcVendor, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Omron}"
                                                 Foreground="White" FontSize="13" Margin="5"/>
                                    <RadioButton Content="Modbus TCP" GroupName="PlcVendor"
                                                 IsChecked="{Binding SelectedPlcVendor, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Modbus}"
                                                 Foreground="White" FontSize="13" Margin="5"/>
                                    <RadioButton Content="None (No PLC)" GroupName="PlcVendor"
                                                 IsChecked="{Binding SelectedPlcVendor, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=None}"
                                                 Foreground="White" FontSize="13" Margin="5"/>
                                </StackPanel>
                            </Border>

                            <!-- Performance & Stability -->
                            <TextBlock Text="Performance &amp; Stability" Style="{StaticResource LabelStyle}"/>
                            <Border Background="#252526" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="Polling Interval (ms)" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding PollingIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>

                                    <CheckBox Content="Use Heartbeat" IsChecked="{Binding UseHeartbeat}"
                                              Foreground="White" FontSize="13" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding HeartbeatAddress, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}" Margin="0,0,0,10"
                                             IsEnabled="{Binding UseHeartbeat}">
                                        <TextBox.Tag>
                                            <TextBlock Text="Heartbeat Address (e.g. D100)" Foreground="#666666"/>
                                        </TextBox.Tag>
                                    </TextBox>

                                    <CheckBox Content="Auto Reconnect" IsChecked="{Binding AutoReconnect}"
                                              Foreground="White" FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <!-- Data Synchronization -->
                            <TextBlock Text="Data Synchronization" Style="{StaticResource LabelStyle}"/>
                            <Border Background="#252526" CornerRadius="6" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Write Mode" Style="{StaticResource LabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding WriteModes}"
                                              SelectedItem="{Binding WriteMode}"
                                              Style="{StaticResource ComboStyle}" Margin="0,0,0,10"/>

                                    <TextBlock Text="Endian Mode" Style="{StaticResource LabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding EndianModes}"
                                              SelectedItem="{Binding EndianMode}"
                                              Style="{StaticResource ComboStyle}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Right Column: Communication Settings -->
                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="12,0,0,0">

                            <!-- Communication Type -->
                            <TextBlock Text="Communication Type" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding CommunicationTypes}"
                                      SelectedItem="{Binding SelectedCommunicationType}"
                                      Style="{StaticResource ComboStyle}" Margin="0,0,0,15"/>

                            <!-- Modbus Unit ID (visible when Modbus selected) -->
                            <StackPanel Visibility="{Binding IsModbusVendor, Converter={StaticResource BoolToVisConverter}}">
                                <TextBlock Text="Modbus Unit ID (1-255)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding ModbusUnitId, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}" Margin="0,0,0,15"/>
                            </StackPanel>

                            <!-- Ethernet Settings (visible when NOT Serial) -->
                            <StackPanel Visibility="{Binding IsEthernetMode, Converter={StaticResource BoolToVisConverter}}">
                                <TextBlock Text="PLC IP Address" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding PlcIpAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}" Margin="0,0,0,15"/>

                                <TextBlock Text="PLC Port" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding PlcPort, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}" Margin="0,0,0,15"/>
                            </StackPanel>

                            <!-- Serial Settings (visible when Serial selected) -->
                            <StackPanel Visibility="{Binding IsSerialMode, Converter={StaticResource BoolToVisConverter}}">
                                <TextBlock Text="Serial Port" Foreground="#FFD700" FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Port Name" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding SerialPortName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>

                                <TextBlock Text="Baud Rate" Style="{StaticResource LabelStyle}"/>
                                <ComboBox ItemsSource="{Binding BaudRateOptions}"
                                          SelectedItem="{Binding BaudRate}"
                                          Style="{StaticResource ComboStyle}" Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Data Bits" Style="{StaticResource LabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding DataBitsOptions}"
                                                  SelectedItem="{Binding DataBits}"
                                                  Style="{StaticResource ComboStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Parity" Style="{StaticResource LabelStyle}"/>
                                        <ComboBox ItemsSource="{Binding SerialParities}"
                                                  SelectedItem="{Binding Parity}"
                                                  Style="{StaticResource ComboStyle}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Stop Bits" Style="{StaticResource LabelStyle}" Margin="0,10,0,6"/>
                                <ComboBox ItemsSource="{Binding SerialStopBitsValues}"
                                          SelectedItem="{Binding StopBits}"
                                          Style="{StaticResource ComboStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer with Navigation -->
        <Border Grid.Row="2" Background="#252526" Padding="30,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← Back"
                        Command="{Binding GoBackCommand}"
                        IsEnabled="{Binding CanGoBack}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Left" Width="100"/>

                <Button Grid.Column="1" Content="{Binding NextButtonText}"
                        Command="{Binding GoNextCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Right" MinWidth="120"/>
            </Grid>
        </Border>
    </Grid>
</Window>
